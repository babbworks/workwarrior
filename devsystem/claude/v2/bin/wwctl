#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

usage() {
  cat << 'EOF'
wwctl — Workwarrior Dev System CLI

Usage: wwctl <command> [args]

Commands:
  status                                  Show system readiness and active task summary
  verify-phase1                           Run Phase 1 gate verification (PASS/FAIL per criterion)
  new-task <TASK-ID> <"goal">             Generate a task card from template + index in TASKS.md
  dispatch <role> <topic> <card-path>     Create git worktree on agent/<role>/<topic> branch
  gates                                   Print all hard gates (A–E) as a quick reference
  fragility                               Print the serialized and high-fragility file list

Examples:
  wwctl status
  wwctl verify-phase1
  wwctl new-task TASK-002 "Write root CLAUDE.md"
  wwctl dispatch builder write-claude-md tasks/cards/TASK-002.md
  wwctl dispatch explorer docs-drift-audit tasks/cards/TASK-003a.md
  wwctl gates
  wwctl fragility
EOF
}

cmd="${1:-}"
shift || true

case "${cmd}" in
  status)
    "${ROOT}/scripts/system-status.sh" "$@"
    ;;
  verify-phase1)
    "${ROOT}/scripts/verify-phase1.sh" "$@"
    ;;
  new-task)
    "${ROOT}/scripts/new-task.sh" "$@"
    ;;
  dispatch)
    "${ROOT}/scripts/dispatch-worktree.sh" "$@"
    ;;
  gates)
    echo "Hard Gates A–E (all are merge blockers):"
    echo ""
    grep -A1 "^  [A-E]:" "${ROOT}/config/gates.yaml" | grep -v "^--$" | \
      sed 's/^  //' | sed 's/name:/Gate/' | sed 's/rule:/  →/'
    ;;
  fragility)
    echo "Serialized ownership (never parallel):"
    sed 's/^/  /' "${ROOT}/config/serialization-paths.txt"
    echo ""
    echo "High-fragility (require Orchestrator approval + integration tests):"
    echo "  lib/github-*.sh"
    echo "  lib/sync-*.sh"
    echo "  services/custom/github-sync.sh"
    echo ""
    echo "Full policy: fragility-register.md"
    ;;
  "" | -h | --help | help)
    usage
    ;;
  *)
    echo "ERROR: Unknown command: ${cmd}" >&2
    echo ""
    usage
    exit 1
    ;;
esac
