#TWEAKS


#reports
report.mainrep.description=My main report with UDAs
report.mainrep.columns=id,project,priority,bus,tags,cond,recur,scheduled.countdown,due.relative,until.remaining,description,urgency
report.mainrep.labels=ID,Project,Pri,Business,Tags,Conditions,Recur,Scheduled,Due,Until,Description,Urg
report.mainrep.sort=urgency-
report.mainrep.filter=status:pending
report.mainrep.suppress.empty.columns=off

report.xyz12345.description=Test
report.xyz12345.columns=id,description
report.xyz12345.sort=id+
report.xyz12345.filter=status:pending
uda.reviewed.type=date
uda.reviewed.label=Reviewed
report._reviewed.description=Tasksh review report.  Adjust the filter to your needs.
report._reviewed.columns=uuid
report._reviewed.sort=reviewed+,modified+
report._reviewed.filter=( reviewed.none: or reviewed.before:now-6days ) and ( +PENDING or +WAITING )
