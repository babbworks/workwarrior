# ============================================================================
# CUSTOM COMMAND
# ============================================================================

cmd_custom() {
  local action="${1:-}"
  shift 2>/dev/null || true

  case "$action" in
    journals)
      "$WW_BASE/services/custom/configure-journals.sh" "$@"
      ;;
    tasks)
      "$WW_BASE/services/custom/configure-tasks.sh" "$@"
      ;;
    times)
      "$WW_BASE/services/custom/configure-times.sh" "$@"
      ;;
    ledgers)
      "$WW_BASE/services/custom/configure-ledgers.sh" "$@"
      ;;
    issues)
      "$WW_BASE/services/custom/configure-issues.sh" "$@"
      ;;
    list)
      echo "Available custom services:"
      echo ""
      for service in "$WW_BASE/services/custom/"*.sh; do
        if [[ -f "$service" && -x "$service" ]]; then
          local name
          name="$(basename "$service" .sh)"
          # Extract description from service file
          local desc
          desc=$(grep "^# Description:" "$service" | sed 's/# Description: //')
          if [[ -n "$desc" ]]; then
            echo "  $name - $desc"
          else
            echo "  $name"
          fi
        fi
      done
      echo ""
      echo "Usage: ww custom <service-name>"
      echo "   or: j custom (for journals configuration)"
      echo "   or: custom journals (alternative)"
      echo ""
      ;;
    ""|help|-h|--help)
      cat << EOF
Custom Services

Usage: ww custom <service> [arguments]

Available Services:
  journals   Configure journal settings (requires active profile)
  tasks      Configure TaskWarrior settings (requires active profile)
  times      Configure TimeWarrior settings (requires active profile)
  ledgers    Configure ledger settings (requires active profile)
  issues     Configure bugwarrior issue synchronization (requires active profile)

Shortcuts:
  j custom              Same as 'ww custom journals'
  t custom              Same as 'ww custom tasks'
  a custom              Same as 'ww custom times'
  l custom              Same as 'ww custom ledgers' (profile-scoped only)
  i custom              Same as 'ww custom issues'
  custom journals       Same as 'ww custom journals'
  custom tasks          Same as 'ww custom tasks'
  custom times          Same as 'ww custom times'
  custom ledgers        Same as 'ww custom ledgers'
  custom issues         Same as 'ww custom issues'

Examples:
  ww custom journals    Configure journal settings
  ww custom tasks       Configure TaskWarrior settings
  ww custom times       Configure TimeWarrior settings
  ww custom ledgers     Configure ledger settings
  ww custom issues      Configure issue synchronization
  ww custom list        List available custom services
  j custom              Quick access to journal configuration
  l custom              Quick access to ledger configuration
  i custom              Quick access to issues configuration

Note: Most custom services require an active profile.
Activate a profile with: p-<profile-name>

EOF
      ;;
    *)
      log_error "Unknown custom service: $action"
      echo "Run 'ww custom list' to see available services"
      exit 1
      ;;
  esac
}

# ============================================================================
# QUESTIONS COMMAND
# ============================================================================

cmd_questions() {
  local action="${1:-}"
  shift 2>/dev/null || true

  # Resolve profile — use scope context (handles --profile flag and last-used profile)
  local q_base=""
  if [[ -n "${WORKWARRIOR_BASE:-}" ]]; then
    q_base="$WORKWARRIOR_BASE/services/questions"
  elif [[ -n "${WARRIOR_PROFILE:-}" ]]; then
    q_base="$WW_BASE/profiles/$WARRIOR_PROFILE/services/questions"
  else
    # Try active profile from state file, then last profile
    local try_prof=""
    if [[ -f "$WW_BASE/.state/active_profile" ]]; then
      try_prof="$(cat "$WW_BASE/.state/active_profile" 2>/dev/null | tr -d '[:space:]')"
    fi
    if [[ -z "$try_prof" ]] || [[ ! -d "$WW_BASE/profiles/$try_prof" ]]; then
      try_prof="$(get_last_profile 2>/dev/null || true)"
    fi
    if [[ -n "$try_prof" && -d "$WW_BASE/profiles/$try_prof" ]]; then
      q_base="$WW_BASE/profiles/$try_prof/services/questions"
      export WORKWARRIOR_BASE="$WW_BASE/profiles/$try_prof"
      export WARRIOR_PROFILE="$try_prof"
      export TASKRC="$WW_BASE/profiles/$try_prof/.taskrc"
    else
      log_error "No active profile — activate one first: p-<profile-name>"
      exit 1
    fi
  fi

  local templates_dir="$q_base/templates"
  mkdir -p "$templates_dir"/{task,journal,time,list,ledger,custom}

  case "$action" in
    list|"")
      _q_list_all "$templates_dir"
      ;;
    new)
      local service="${1:-custom}"
      if [[ ! "$service" =~ ^(task|journal|time|list|ledger|custom)$ ]]; then
        log_error "Invalid service: $service. Use: task, journal, time, list, ledger, custom"
        exit 1
      fi
      if [[ "$service" == "task" ]]; then
        _q_create_task_template "$templates_dir"
      else
        _q_create_template "$templates_dir" "$service"
      fi
      ;;
    edit)
      local name="${1:-}"
      if [[ -z "$name" ]]; then
        log_error "Template name required: ww q edit <name>"
        exit 1
      fi
      local found=$(_q_find_template "$templates_dir" "$name")
      if [[ -z "$found" ]]; then
        log_error "Template '$name' not found"
        exit 1
      fi
      ${EDITOR:-nano} "$found"
      log_success "Template saved"
      ;;
    delete)
      local name="${1:-}"
      local flag="${2:-}"
      if [[ -z "$name" ]]; then
        log_error "Template name required: ww q delete <name>"
        exit 1
      fi
      local found=$(_q_find_template "$templates_dir" "$name")
      if [[ -z "$found" ]]; then
        log_error "Template '$name' not found"
        exit 1
      fi
      if [[ "$flag" != "--yes" ]]; then
        read -p "Delete template '$name'? (y/N): " confirm
        [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Cancelled"; exit 0; }
      fi
      rm -f "$found"
      log_success "Deleted template '$name'"
      ;;
    task|journal|time|list|ledger|custom)
      local template_name="${1:-}"
      if [[ -z "$template_name" ]]; then
        _q_list_service "$templates_dir" "$action"
      else
        _q_run_template "$templates_dir" "$action" "$template_name"
      fi
      ;;
    help|-h|--help)
      cat << 'QEOF'
Questions Service — Templated Workflows

Usage:
  ww q                         List all templates
  ww q list                    List all templates
  ww q new <service>           Create new template (task, journal, time, list, ledger, custom)
  ww q <service>               List templates for a service
  ww q <service> <template>    Run a template
  ww q edit <template>         Edit template in $EDITOR
  ww q delete <template>       Delete a template

Services: task, journal, time, list, ledger, custom

Examples:
  ww q new journal             Create a journal question template
  ww q new task                Create a task template (with UDA picker)
  ww q journal daily           Run the 'daily' journal template
  ww q task standup            Run the 'standup' task template
QEOF
      ;;
    *)
      log_error "Unknown questions command: $action"
      echo "Run: ww q help"
      exit 1
      ;;
  esac
}

_q_list_all() {
  local templates_dir="$1"
  local global_dir="$WW_BASE/services/questions/templates"
  echo "All Templates:"
  echo "=============="
  local found=0
  for service in task journal time list ledger custom; do
    local files=()
    # Profile templates
    local dir="$templates_dir/$service"
    if [[ -d "$dir" ]]; then
      while IFS= read -r f; do
        files+=("$(basename "$f" .json)")
      done < <(find "$dir" -maxdepth 1 -name "*.json" -type f 2>/dev/null | sort)
    fi
    # Global templates (add if not already found)
    local gdir="$global_dir/$service"
    if [[ -d "$gdir" ]]; then
      while IFS= read -r f; do
        local bn="$(basename "$f" .json)"
        local already=0
        for existing in "${files[@]}"; do [[ "$existing" == "$bn" ]] && already=1 && break; done
        [[ $already -eq 0 ]] && files+=("$bn")
      done < <(find "$gdir" -maxdepth 1 -name "*.json" -type f 2>/dev/null | sort)
    fi
    if [[ ${#files[@]} -gt 0 ]]; then
      found=1
      echo "$service:"
      for f in "${files[@]}"; do
        echo "  $f"
      done
    fi
  done
  if [[ $found -eq 0 ]]; then
    echo "(no templates)"
    echo "Create one: ww q new journal"
  fi
}

_q_list_service() {
  local templates_dir="$1"
  local service="$2"
  local global_dir="$WW_BASE/services/questions/templates"
  echo "Templates for $service:"
  local files=()
  for dir in "$templates_dir/$service" "$global_dir/$service"; do
    [[ -d "$dir" ]] || continue
    while IFS= read -r f; do
      local bn="$(basename "$f" .json)"
      local already=0
      for existing in "${files[@]}"; do [[ "$existing" == "$bn" ]] && already=1 && break; done
      [[ $already -eq 0 ]] && files+=("$bn")
    done < <(find "$dir" -maxdepth 1 -name "*.json" -type f 2>/dev/null | sort)
  done
  if [[ ${#files[@]} -eq 0 ]]; then
    echo "  (none)"
    echo "Create one: ww q new $service"
  else
    for f in "${files[@]}"; do
      echo "  $f"
    done
  fi
}

_q_find_template() {
  local templates_dir="$1"
  local name="$2"
  local global_dir="$WW_BASE/services/questions/templates"
  # Profile first, then global
  for service in task journal time list ledger custom; do
    local f="$templates_dir/$service/${name}.json"
    if [[ -f "$f" ]]; then echo "$f"; return 0; fi
    local gf="$global_dir/$service/${name}.json"
    if [[ -f "$gf" ]]; then echo "$gf"; return 0; fi
  done
  return 1
}

_q_create_template() {
  local templates_dir="$1"
  local service="$2"

  read -p "Template name (filename, no spaces): " tname
  if [[ -z "$tname" || ! "$tname" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    log_error "Invalid name. Use letters, numbers, dots, hyphens, underscores."
    return 1
  fi
  local tfile="$templates_dir/$service/${tname}.json"
  if [[ -f "$tfile" ]]; then
    log_error "Template '$tname' already exists in $service"
    return 1
  fi

  read -p "Display name [$tname]: " display_name
  [[ -z "$display_name" ]] && display_name="$tname"
  read -p "Description: " desc

  echo ""
  echo "Enter questions (empty line to finish):"
  local questions=()
  local n=1
  while true; do
    read -p "  Q$n: " qtxt
    [[ -z "$qtxt" ]] && break
    questions+=("$qtxt")
    ((n++))
  done

  if [[ ${#questions[@]} -eq 0 ]]; then
    log_error "At least one question required"
    return 1
  fi

  # Write JSON
  python3 -c "
import json, sys
qs = []
for i, q in enumerate(sys.argv[3:]):
    qs.append({'id': f'q{i+1}', 'text': q, 'type': 'text', 'required': True})
t = {'name': sys.argv[1], 'description': sys.argv[2], 'service': '$service', 'questions': qs,
     'output_format': {'title': sys.argv[1] + ' - {date}', 'tags': ['$service', 'template']}}
with open('$tfile', 'w') as f:
    json.dump(t, f, indent=2)
" "$display_name" "$desc" "${questions[@]}"

  log_success "Created: $tfile"
  echo "Run with: ww q $service $tname"
}

_q_create_task_template() {
  local templates_dir="$1"

  read -p "Template name (filename, no spaces): " tname
  if [[ -z "$tname" || ! "$tname" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    log_error "Invalid name"
    return 1
  fi
  local tfile="$templates_dir/task/${tname}.json"
  if [[ -f "$tfile" ]]; then
    log_error "Template '$tname' already exists"
    return 1
  fi

  read -p "Display name [$tname]: " display_name
  [[ -z "$display_name" ]] && display_name="$tname"
  read -p "Description: " desc

  echo ""
  echo "Enter questions (empty line to finish):"
  local questions=()
  local n=1
  while true; do
    read -p "  Q$n: " qtxt
    [[ -z "$qtxt" ]] && break
    questions+=("$qtxt")
    ((n++))
  done
  if [[ ${#questions[@]} -eq 0 ]]; then
    log_error "At least one question required"
    return 1
  fi

  # UDA picker — interactive search
  echo ""
  echo "Select UDAs to include (type name to search, number to select, 'list' to browse, Enter to finish):"
  echo "─────────────────────────────────────────────────────────────"

  local taskrc="${TASKRC:-$WORKWARRIOR_BASE/.taskrc}"
  local uda_names=()
  local uda_types=()
  local uda_labels=()

  while IFS= read -r line; do
    local uname="${line%%=*}"
    uname="${uname#uda.}"
    uname="${uname%.type}"
    local utype="${line#*=}"
    [[ "$uname" =~ ^(github|gitlab|jira|trello|bw_|sync_) ]] && continue
    local ulabel=""
    ulabel=$(grep "^uda\.${uname}\.label=" "$taskrc" 2>/dev/null | head -1 | cut -d= -f2)
    [[ -z "$ulabel" ]] && ulabel="$uname"
    uda_names+=("$uname")
    uda_types+=("$utype")
    uda_labels+=("$ulabel")
  done < <(grep "^uda\..*\.type=" "$taskrc" 2>/dev/null | sort)

  local selected_udas=()
  if [[ ${#uda_names[@]} -gt 0 ]]; then
    while true; do
      local sel_display=""
      if [[ ${#selected_udas[@]} -gt 0 ]]; then
        sel_display=" [selected: ${selected_udas[*]}]"
      fi
      read -p "UDA${sel_display}: " uda_input
      [[ -z "$uda_input" ]] && break

      if [[ "$uda_input" == "list" ]]; then
        for i in "${!uda_names[@]}"; do
          printf "  %3d. %-25s %-10s %s\n" "$((i+1))" "${uda_names[$i]}" "(${uda_types[$i]})" "${uda_labels[$i]}"
        done
        continue
      fi

      # Number input
      if [[ "$uda_input" =~ ^[0-9]+$ ]]; then
        local num=$uda_input
        if (( num >= 1 && num <= ${#uda_names[@]} )); then
          selected_udas+=("${uda_names[$((num-1))]}")
          echo "  + ${uda_names[$((num-1))]}"
        else
          echo "  (invalid number, 1-${#uda_names[@]})"
        fi
        continue
      fi

      # Text search — show matches
      local matches=()
      local match_indices=()
      for i in "${!uda_names[@]}"; do
        if [[ "${uda_names[$i]}" == *"$uda_input"* || "${uda_labels[$i]}" == *"$uda_input"* ]]; then
          matches+=("${uda_names[$i]}")
          match_indices+=("$i")
        fi
      done

      if [[ ${#matches[@]} -eq 0 ]]; then
        echo "  (no match for '$uda_input')"
      elif [[ ${#matches[@]} -eq 1 ]]; then
        selected_udas+=("${matches[0]}")
        echo "  + ${matches[0]}"
      else
        echo "  matches:"
        for j in "${!matches[@]}"; do
          local idx="${match_indices[$j]}"
          printf "    %3d. %-25s %s\n" "$((idx+1))" "${matches[$j]}" "${uda_labels[$idx]}"
        done
      fi
    done
  fi

  echo ""
  echo "Selected UDAs: ${selected_udas[*]:-none}"

  # Write JSON with UDA fields
  python3 -c "
import json, sys

questions_text = sys.argv[3:3+int(sys.argv[1])]
uda_list = sys.argv[3+int(sys.argv[1]):]
display = sys.argv[2]

qs = []
for i, q in enumerate(questions_text):
    qs.append({'id': f'q{i+1}', 'text': q, 'type': 'text', 'required': i == 0})

# Add UDA fields as questions
for u in uda_list:
    qs.append({'id': f'uda_{u}', 'text': f'{u}', 'type': 'uda', 'required': False, 'uda_name': u})

t = {
    'name': display,
    'description': sys.argv[2+int(sys.argv[1])+1] if len(sys.argv) > 2+int(sys.argv[1])+1 else '',
    'service': 'task',
    'questions': qs,
    'udas': uda_list,
    'output_format': {'title': display + ' - {date}', 'tags': ['task', 'template']}
}
with open('$tfile', 'w') as f:
    json.dump(t, f, indent=2)
" "${#questions[@]}" "$display_name" "${questions[@]}" "$desc" "${selected_udas[@]}"

  log_success "Created task template: $tfile"
  echo "Run with: ww q task $tname"
}

_q_run_template() {
  local templates_dir="$1"
  local service="$2"
  local template_name="$3"
  local tfile="$templates_dir/$service/${template_name}.json"
  local global_dir="$WW_BASE/services/questions/templates"

  # Check profile first, then global
  if [[ ! -f "$tfile" ]]; then
    tfile="$global_dir/$service/${template_name}.json"
  fi
  if [[ ! -f "$tfile" ]]; then
    log_error "Template '$template_name' not found in $service"
    return 1
  fi

  if ! command -v python3 &>/dev/null; then
    log_error "python3 required for template processing"
    return 1
  fi

  # Parse and prompt via temp Python script
  local _q_py=$(mktemp /tmp/ww_q_XXXXXX.py)
  cat > "$_q_py" << 'PYEOF'
import json, sys, os, subprocess
from datetime import datetime

tfile = os.environ.get('_Q_TFILE', '')
service = os.environ.get('_Q_SERVICE', '')
taskrc = os.environ.get('_Q_TASKRC', '')
ww_base = os.environ.get('_Q_WWBASE', '')

with open(tfile) as f:
    template = json.load(f)

print(f"\n{template['name']}")
print(f"{template.get('description', '')}")
print("=" * 50)

answers = {}
for q in template['questions']:
    qtype = q.get('type', 'text')
    label = q['text']
    required = q.get('required', False)

    while True:
        val = input(f"  {label}: ").strip()
        if not val and required:
            print("    (required)")
            continue
        break
    answers[q['id']] = val

print("\n" + "=" * 50)

if service == 'journal':
    # Write to journal
    journal_file = ""
    if ww_base:
        import re
        jrnl_yaml = os.path.join(ww_base, "jrnl.yaml")
        if os.path.isfile(jrnl_yaml):
            with open(jrnl_yaml) as jf:
                in_journals = False
                for line in jf:
                    if line.strip() == "journals:":
                        in_journals = True
                        continue
                    if in_journals:
                        m = re.match(r'^  default:\s*(.+)', line)
                        if m:
                            journal_file = m.group(1).strip()
                            break
    if not journal_file:
        journal_file = os.path.join(ww_base, "journals", os.path.basename(ww_base) + ".txt")

    ts = datetime.now().strftime("%Y-%m-%d %H:%M")
    entry_parts = [f"[{ts}] {template['name']}"]
    for qid, val in answers.items():
        if val:
            entry_parts.append(f"  {qid}: {val}")
    entry = "\n".join(entry_parts) + "\n"

    with open(journal_file, "a") as jf:
        jf.write("\n" + entry)
    print(f"✓ Written to journal: {journal_file}")

elif service == 'task':
    # Create task via task CLI
    desc = answers.get('q1', '')
    if not desc:
        print("✗ No description (q1) provided")
        sys.exit(1)

    cmd = ["task", "rc.confirmation=no", "add", desc]
    tags = template.get('output_format', {}).get('tags', [])
    for tag in tags:
        cmd.append(f"+{tag}")

    env = dict(os.environ)
    if taskrc:
        env["TASKRC"] = taskrc
        taskdata = os.path.join(os.path.dirname(taskrc), ".task")
        env["TASKDATA"] = taskdata

    r = subprocess.run(cmd, capture_output=True, text=True, env=env)
    if r.returncode != 0:
        print(f"✗ Failed to create task: {r.stderr}")
        sys.exit(1)
    print(f"✓ Task created: {desc}")

    # Get new task ID
    r2 = subprocess.run(["task", "rc.confirmation=no", "+LATEST", "ids"],
                        capture_output=True, text=True, env=env)
    task_id = r2.stdout.strip().split()[-1] if r2.stdout.strip() else ""

    # Add annotations for non-description answers
    for qid, val in answers.items():
        if qid == 'q1' or not val:
            continue
        q_obj = next((q for q in template['questions'] if q['id'] == qid), None)
        if q_obj and q_obj.get('type') == 'uda' and task_id:
            uda_name = q_obj.get('uda_name', qid.replace('uda_', ''))
            subprocess.run(["task", "rc.confirmation=no", task_id, "modify", f"{uda_name}:{val}"],
                          capture_output=True, text=True, env=env)
            print(f"  set {uda_name}={val}")
        elif task_id:
            label = q_obj['text'] if q_obj else qid
            subprocess.run(["task", "rc.confirmation=no", task_id, "annotate", f"{label}: {val}"],
                          capture_output=True, text=True, env=env)
            print(f"  annotated: {label}: {val}")

    if task_id:
        print(f"  Task ID: {task_id}")

elif service == 'time':
    tags = answers.get('q1', '')
    desc = answers.get('q2', '')
    if tags:
        env = dict(os.environ)
        if ww_base:
            env["TIMEWARRIORDB"] = os.path.join(ww_base, ".timewarrior")
        subprocess.run(["timew", "start"] + tags.split(), env=env)
        print(f"✓ Started tracking: {tags}")
    if desc:
        journal_file = os.path.join(ww_base, "journals", os.path.basename(ww_base) + ".txt") if ww_base else ""
        if journal_file and os.path.isfile(os.path.dirname(journal_file)):
            ts = datetime.now().strftime("%Y-%m-%d %H:%M")
            with open(journal_file, "a") as jf:
                jf.write(f"\n[{ts}] [time:{tags}] {desc}\n")

else:
    # Generic: just print answers
    for qid, val in answers.items():
        if val:
            print(f'  {qid}: {val}')

PYEOF
  _Q_TFILE="$tfile" _Q_SERVICE="$service" _Q_TASKRC="${TASKRC:-}" _Q_WWBASE="${WORKWARRIOR_BASE:-}" python3 "$_q_py"
  local _q_rc=$?
  rm -f "$_q_py"
  return $_q_rc
}

# ============================================================================
# SHORTCUT COMMAND
# ============================================================================

cmd_shortcut() {
  local action="${1:-}"
  shift 2>/dev/null || true

  # Source shortcut registry library
  if [[ -f "$WW_BASE/lib/shortcode-registry.sh" ]]; then
    source "$WW_BASE/lib/shortcode-registry.sh"
  else
    log_error "Shortcut registry not found"
    exit 1
  fi

  case "$action" in
    list|"")
      display_shortcuts "${1:-all}"
      ;;
    compact)
      display_shortcuts_compact
      ;;
    info)
      if [[ -z "${1:-}" ]]; then
        log_error "Shortcut key required"
        echo "Usage: ww shortcut info <key>"
        exit 1
      fi
      display_shortcut_info "$1"
      ;;
    add)
      if [[ -z "${1:-}" || -z "${2:-}" || -z "${3:-}" || -z "${4:-}" || -z "${5:-}" ]]; then
        log_error "Missing arguments for shortcut add"
        echo "Usage: ww shortcut add <key> <name> <category> <description> <command> [requires_profile]"
        exit 1
      fi
      add_user_shortcut "$1" "$2" "$3" "$4" "$5" "${6:-false}"
      ;;
    remove|rm|delete)
      if [[ -z "${1:-}" ]]; then
        log_error "Shortcut key required"
        echo "Usage: ww shortcut remove <key>"
        exit 1
      fi
      remove_user_shortcut "$1"
      ;;
    help|-h|--help)
      cat << EOF
Shortcut Reference

Usage: ww shortcut <action> [arguments]

Actions:
  list [category]   List shortcuts (categories: all, profile, function, service, global)
  info <key>        Show details for a shortcut
  compact           Compact list (for quick reference)
  add <args>        Add or update a user shortcut override
  remove <key>      Remove a user shortcut override

Examples:
  ww shortcut list
  ww shortcut list profile
  ww shortcut info j
  ww shortcut compact
  ww shortcut add x "Example" global "Example command" "echo hi" false
  ww shortcut remove x

EOF
      ;;
    *)
      log_error "Unknown shortcut action: $action"
      echo "Run 'ww shortcut help' for usage"
      exit 1
      ;;
  esac
}

# ============================================================================
# JOURNAL COMMAND (list-first UX)
# ============================================================================

cmd_journal() {
  local action="${1:-}"
  shift 2>/dev/null || true

  case "$action" in
    list|"")
      if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name>."
        exit 1
      fi
      local cfg="$WORKWARRIOR_BASE/jrnl.yaml"
      if [[ ! -f "$cfg" ]]; then
        log_error "jrnl.yaml not found: $cfg"
        exit 1
      fi
      local names=()
      mapfile -t names < <(awk '
        /^journals:/ { in_j=1; next }
        in_j && /^[^ ]/ { in_j=0 }
        in_j && /^  [a-zA-Z0-9_-]+:/ {
          name=$1; sub(":", "", name);
          if (name != "default") print "  • " name
        }
      ' "$cfg"
      )
      local clean=()
      for entry in "${names[@]}"; do
        clean+=( "${entry#  • }" )
      done
      if [[ "$WW_OUTPUT_MODE" == "json" ]]; then
        printf '{"profile":"%s","journals":' "${WARRIOR_PROFILE:-active}"
        print_json_array "${clean[@]}"
        printf '}\n'
      elif [[ "$WW_OUTPUT_MODE" == "compact" ]]; then
        if (( ${#clean[@]} > 0 )); then
          printf '%s\n' "${clean[@]}"
        fi
      else
        echo "Journals (${WARRIOR_PROFILE:-active}):"
        if (( ${#clean[@]} > 0 )); then
          printf '  • %s\n' "${clean[@]}"
        else
          echo "  (none)"
        fi
      fi
      ;;
    add|create)
      if [[ -z "${WARRIOR_PROFILE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name> or use --profile."
        exit 1
      fi
      if [[ -z "${1:-}" ]]; then
        log_error "Journal name required"
        echo "Usage: ww journal add <name>"
        exit 1
      fi
      if ! add_journal_to_profile "$WARRIOR_PROFILE" "$1"; then
        exit 1
      fi
      ;;
    remove|delete|rm)
      if [[ -z "${WARRIOR_PROFILE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name> or use --profile."
        exit 1
      fi
      if [[ -z "${1:-}" ]]; then
        log_error "Journal name required"
        echo "Usage: ww journal remove <name>"
        exit 1
      fi
      if ! remove_journal_from_profile "$WARRIOR_PROFILE" "$1"; then
        exit 1
      fi
      ;;
    rename)
      if [[ -z "${WARRIOR_PROFILE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name> or use --profile."
        exit 1
      fi
      if [[ -z "${1:-}" || -z "${2:-}" ]]; then
        log_error "Old and new journal names required"
        echo "Usage: ww journal rename <old> <new>"
        exit 1
      fi
      if ! rename_journal_in_profile "$WARRIOR_PROFILE" "$1" "$2"; then
        exit 1
      fi
      ;;
    help|-h|--help)
      show_help_journal
      ;;
    *)
      log_error "Unknown journal action: $action"
      echo "Run 'ww journal help' for usage"
      exit 1
      ;;
  esac
}

# ============================================================================
# LEDGER COMMAND (list-first UX)
# ============================================================================

cmd_ledger() {
  local action="${1:-}"
  shift 2>/dev/null || true

  case "$action" in
    list|"")
      if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name>."
        exit 1
      fi
      local cfg="$WORKWARRIOR_BASE/ledgers.yaml"
      if [[ ! -f "$cfg" ]]; then
        log_error "ledgers.yaml not found: $cfg"
        exit 1
      fi
      local names=()
      mapfile -t names < <(awk '
        /^ledgers:/ { in_l=1; next }
        in_l && /^[^ ]/ { in_l=0 }
        in_l && /^  [a-zA-Z0-9_-]+:/ {
          name=$1; sub(":", "", name);
          if (name != "default") print "  • " name
        }
      ' "$cfg"
      )
      local clean=()
      for entry in "${names[@]}"; do
        clean+=( "${entry#  • }" )
      done
      if [[ "$WW_OUTPUT_MODE" == "json" ]]; then
        printf '{"profile":"%s","ledgers":' "${WARRIOR_PROFILE:-active}"
        print_json_array "${clean[@]}"
        printf '}\n'
      elif [[ "$WW_OUTPUT_MODE" == "compact" ]]; then
        if (( ${#clean[@]} > 0 )); then
          printf '%s\n' "${clean[@]}"
        fi
      else
        echo "Ledgers (${WARRIOR_PROFILE:-active}):"
        if (( ${#clean[@]} > 0 )); then
          printf '  • %s\n' "${clean[@]}"
        else
          echo "  (none)"
        fi
      fi
      ;;
    add|create)
      if [[ -z "${WARRIOR_PROFILE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name> or use --profile."
        exit 1
      fi
      if [[ -z "${1:-}" ]]; then
        log_error "Ledger name required"
        echo "Usage: ww ledger add <name>"
        exit 1
      fi
      if ! add_ledger_to_profile "$WARRIOR_PROFILE" "$1"; then
        exit 1
      fi
      ;;
    remove|delete|rm)
      if [[ -z "${WARRIOR_PROFILE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name> or use --profile."
        exit 1
      fi
      if [[ -z "${1:-}" ]]; then
        log_error "Ledger name required"
        echo "Usage: ww ledger remove <name>"
        exit 1
      fi
      if ! remove_ledger_from_profile "$WARRIOR_PROFILE" "$1"; then
        exit 1
      fi
      ;;
    rename)
      if [[ -z "${WARRIOR_PROFILE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name> or use --profile."
        exit 1
      fi
      if [[ -z "${1:-}" || -z "${2:-}" ]]; then
        log_error "Old and new ledger names required"
        echo "Usage: ww ledger rename <old> <new>"
        exit 1
      fi
      if ! rename_ledger_in_profile "$WARRIOR_PROFILE" "$1" "$2"; then
        exit 1
      fi
      ;;
    help|-h|--help)
      show_help_ledger
      ;;
    *)
      log_error "Unknown ledger action: $action"
      echo "Run 'ww ledger help' for usage"
      exit 1
      ;;
  esac
}

# ============================================================================
# SCHEDULE COMMAND
# ============================================================================

cmd_schedule() {
  local subcommand="${1:-status}"
  shift 2>/dev/null || true

  # Upstream: https://github.com/00sapo/taskcheck
  # Author: 00sapo · MIT License · Python
  # Binary: taskcheck
  # Config: appdirs.user_config_dir("task")/taskcheck.toml (global path)
  # ww manages per-profile config by copying to/from global location before run.

  _schedule_require_profile() {
    if [[ -z "${TASKRC:-}" || -z "${TASKDATA:-}" ]]; then
      log_error "No active profile — activate one first: p-<profile-name>"
      exit 1
    fi
  }

  _schedule_profile_config_dir() {
    echo "${WORKWARRIOR_BASE:-}/.config/taskcheck"
  }

  _schedule_enabled_flag() {
    echo "$(_schedule_profile_config_dir)/enabled"
  }

  _schedule_profile_toml() {
    echo "$(_schedule_profile_config_dir)/taskcheck.toml"
  }

  _schedule_global_config_dir() {
    python3 -c "import appdirs; print(appdirs.user_config_dir('task'))" 2>/dev/null \
      || echo "${HOME}/.config/task"
  }

  _schedule_global_toml() {
    echo "$(_schedule_global_config_dir)/taskcheck.toml"
  }

  # Copy profile config to global location before running taskcheck
  _schedule_activate_config() {
    local profile_toml
    profile_toml=$(_schedule_profile_toml)
    local global_toml
    global_toml=$(_schedule_global_toml)
    if [[ -f "${profile_toml}" ]]; then
      mkdir -p "$(dirname "${global_toml}")"
      cp "${profile_toml}" "${global_toml}"
    fi
  }

  case "$subcommand" in
    install)
      if command -v taskcheck &>/dev/null; then
        log_success "taskcheck already installed: $(taskcheck --version 2>/dev/null || echo 'version unknown')"
        return 0
      fi
      if ! command -v pipx &>/dev/null; then
        log_error "pipx not found. Install with: brew install pipx"
        exit 1
      fi
      echo "Installing taskcheck..."
      echo "  Upstream: https://github.com/00sapo/taskcheck"
      echo "  Author:   00sapo · MIT License"
      pipx install taskcheck
      log_success "taskcheck installed"
      ;;
    enable)
      _schedule_require_profile
      local config_dir
      config_dir=$(_schedule_profile_config_dir)
      mkdir -p "${config_dir}"
      touch "$(_schedule_enabled_flag)"
      # Create default config if none exists
      if [[ ! -f "$(_schedule_profile_toml)" ]]; then
        if command -v taskcheck &>/dev/null; then
          echo "Creating default taskcheck config for profile '${WARRIOR_PROFILE:-active}'..."
          _schedule_activate_config
          taskcheck --install 2>/dev/null || true
          # Copy the generated global config to profile
          local global_toml
          global_toml=$(_schedule_global_toml)
          [[ -f "${global_toml}" ]] && cp "${global_toml}" "$(_schedule_profile_toml)"
        else
          log_warning "taskcheck not installed — run 'ww schedule install' then 'ww schedule config' to set up"
        fi
      fi
      log_success "Auto-scheduling enabled for profile '${WARRIOR_PROFILE:-active}'"
      echo "  Config: $(_schedule_profile_toml)"
      echo "  Run:    ww schedule run"
      ;;
    disable)
      _schedule_require_profile
      local flag
      flag=$(_schedule_enabled_flag)
      if [[ -f "${flag}" ]]; then
        rm "${flag}"
        log_success "Auto-scheduling disabled for profile '${WARRIOR_PROFILE:-active}'"
        echo "  Config preserved at: $(_schedule_profile_toml)"
      else
        echo "Auto-scheduling was not enabled for this profile."
      fi
      ;;
    status)
      _schedule_require_profile
      local flag
      flag=$(_schedule_enabled_flag)
      local profile_toml
      profile_toml=$(_schedule_profile_toml)
      echo "Schedule status for profile '${WARRIOR_PROFILE:-active}':"
      echo ""
      if [[ -f "${flag}" ]]; then
        echo "  enabled:  yes"
      else
        echo "  enabled:  no  (run: ww schedule enable)"
      fi
      if [[ -f "${profile_toml}" ]]; then
        echo "  config:   ${profile_toml}"
      else
        echo "  config:   not found (run: ww schedule enable)"
      fi
      echo "  taskcheck: $(command -v taskcheck 2>/dev/null || echo 'not installed')"
      ;;
    run)
      _schedule_require_profile
      local flag
      flag=$(_schedule_enabled_flag)
      if [[ ! -f "${flag}" ]]; then
        log_error "Auto-scheduling is disabled for this profile. Run: ww schedule enable"
        exit 1
      fi
      if ! command -v taskcheck &>/dev/null; then
        log_error "taskcheck not installed — run: ww schedule install"
        exit 1
      fi
      _schedule_activate_config
      taskcheck --taskrc "${TASKRC}" "$@"
      ;;
    config)
      _schedule_require_profile
      local profile_toml
      profile_toml=$(_schedule_profile_toml)
      if [[ ! -f "${profile_toml}" ]]; then
        log_error "No config found. Run: ww schedule enable"
        exit 1
      fi
      "${EDITOR:-vi}" "${profile_toml}"
      ;;
    help|-h|--help)
      cat << 'EOF'
Schedule Command — Automatic Task Scheduler

Schedules tasks into working hours around calendar events, respecting
urgency and dependencies. Adds 'estimated' and 'time_map' UDAs.

Usage:
  ww schedule enable          Enable for active profile + create default config
  ww schedule disable         Disable (config preserved)
  ww schedule status          Show enabled/disabled state
  ww schedule run             Run scheduler
  ww schedule run --dry-run   Preview without writing
  ww schedule config          Edit profile's taskcheck.toml
  ww schedule install         Install taskcheck via pipx
  ww schedule help            Show this help

UDAs added:
  estimated    Numeric — expected hours to complete the task
  time_map     String  — working hours map key (e.g. work, weekend)

Toggle:
  Enable/disable per profile without removing config.
  Config lives at: profiles/<name>/.config/taskcheck/taskcheck.toml

Powered by taskcheck · 00sapo
  https://github.com/00sapo/taskcheck · MIT License
EOF
      ;;
    *)
      log_error "Unknown schedule subcommand: $subcommand"
      cmd_schedule help
      exit 1
      ;;
  esac
}

# ============================================================================
# NEXT COMMAND
# ============================================================================

cmd_next() {
  local subcommand="${1:-}"

  # Upstream: https://github.com/ftapajos/scheduler
  # Author: Flávio Tapajós (ftapajos) · GPL-3.0 · Python
  # Binary: 'next' (installed via pipx install taskwarrior-scheduler)

  case "$subcommand" in
    install)
      if command -v next &>/dev/null && next --help 2>&1 | grep -q taskwarrior; then
        log_success "taskwarrior-scheduler already installed"
        return 0
      fi
      if ! command -v pipx &>/dev/null; then
        log_error "pipx not found. Install with: brew install pipx"
        exit 1
      fi
      echo "Installing taskwarrior-scheduler..."
      echo "  Upstream: https://github.com/ftapajos/scheduler"
      echo "  Author:   Flávio Tapajós (ftapajos) · GPL-3.0"
      pipx install taskwarrior-scheduler
      log_success "taskwarrior-scheduler installed (binary: next)"
      ;;
    help|-h|--help)
      cat << 'EOF'
Next Command — CFS-Inspired Task Recommendation

Recommends which task to work on next by combining TaskWarrior urgency
with TimeWarrior time-already-spent. Prevents high-urgency tasks from
monopolising all attention (inspired by the Linux CFS scheduler).

Usage:
  ww next                     Show recommended next task
  ww next [filters...]        Filter tasks before recommendation
  ww next install             Install taskwarrior-scheduler
  ww next help                Show this help

Examples:
  ww next
  ww next +work
  ww next project:dev

Requires:
  - Active ww profile (TASKRC, TASKDATA, TIMEWARRIORDB set)
  - taskwarrior-scheduler installed (ww next install)
  - TimeWarrior on-modify hook active (already installed per profile)

Powered by taskwarrior-scheduler · Flávio Tapajós (ftapajos)
  https://github.com/ftapajos/scheduler · GPL-3.0
EOF
      ;;
    *)
      if [[ -z "${TASKRC:-}" || -z "${TASKDATA:-}" ]]; then
        log_error "No active profile — activate one first: p-<profile-name>"
        exit 1
      fi
      if ! command -v next &>/dev/null; then
        log_error "taskwarrior-scheduler not installed — run: ww next install"
        exit 1
      fi
      # Pass all args (including the subcommand if it wasn't install/help) as filters
      local filters=()
      [[ -n "$subcommand" ]] && filters+=("$subcommand")
      shift 2>/dev/null || true
      filters+=("$@")
      TASKRC="${TASKRC}" TASKDATA="${TASKDATA}" TIMEWARRIORDB="${TIMEWARRIORDB:-}" \
        next "${filters[@]+${filters[@]}}"
      ;;
  esac
}

# ============================================================================
# SWORD COMMAND — Task Splitting
# ============================================================================

cmd_sword() {
  local subcommand="${1:-}"
  shift 2>/dev/null || true

  case "$subcommand" in
    help|-h|--help|"")
      cat << 'EOF'
Sword Command — Task Splitting

Splits a single task into sequential subtasks with dependencies.
Each subtask depends on the previous one. Due dates are offset by interval.

Usage:
  ww sword <task-id> -p <parts> [--interval <dur>] [--prefix <text>]
  ww sword install              (no install needed — ww-native)
  ww sword help                 Show this help

Options:
  -p <parts>          Number of subtasks to create
  --interval <dur>    Due date offset between parts (default: 1d)
  --prefix <text>     Prefix for subtask descriptions (default: "Part N of:")

Examples:
  ww sword 5 -p 3                    Split task 5 into 3 parts
  ww sword 5 -p 4 --interval 2d     Split with 2-day intervals
  ww sword 12 -p 2 --prefix "Phase" Split into "Phase 1 of: ..." and "Phase 2 of: ..."
EOF
      ;;
    install)
      log_success "Sword is ww-native — no installation needed"
      ;;
    *)
      # Parse: ww sword <task-id> -p <parts> [--interval <dur>] [--prefix <text>]
      local task_id="$subcommand"
      local parts=""
      local interval="1d"
      local prefix="Part"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          -p) parts="$2"; shift 2 ;;
          --interval) interval="$2"; shift 2 ;;
          --prefix) prefix="$2"; shift 2 ;;
          *) shift ;;
        esac
      done

      if [[ -z "$task_id" || -z "$parts" ]]; then
        log_error "Usage: ww sword <task-id> -p <parts>"
        exit 1
      fi

      if [[ -z "${TASKRC:-}" || -z "${TASKDATA:-}" ]]; then
        log_error "No active profile — activate one first: p-<profile-name>"
        exit 1
      fi

      # Get the original task
      local task_json
      task_json=$(task rc.confirmation=no "$task_id" export 2>/dev/null)
      if [[ -z "$task_json" || "$task_json" == "[]" ]]; then
        log_error "Task $task_id not found"
        exit 1
      fi

      local orig_desc
      orig_desc=$(echo "$task_json" | python3 -c "import json,sys; t=json.load(sys.stdin)[0]; print(t['description'])" 2>/dev/null)
      local orig_project
      orig_project=$(echo "$task_json" | python3 -c "import json,sys; t=json.load(sys.stdin)[0]; print(t.get('project',''))" 2>/dev/null)
      local orig_tags
      orig_tags=$(echo "$task_json" | python3 -c "import json,sys; t=json.load(sys.stdin)[0]; print(' '.join('+'+t for t in t.get('tags',[])))" 2>/dev/null)

      if [[ -z "$orig_desc" ]]; then
        log_error "Could not read task $task_id description"
        exit 1
      fi

      echo "Splitting task $task_id into $parts parts:"
      echo "  Original: $orig_desc"
      echo "  Interval: $interval"
      echo ""

      local prev_id=""
      local created_ids=()

      for ((i=1; i<=parts; i++)); do
        local sub_desc="$prefix $i of: $orig_desc"
        local cmd_parts=("add" "$sub_desc")

        # Add project if original had one
        if [[ -n "$orig_project" ]]; then
          cmd_parts+=("project:$orig_project")
        fi

        # Add tags if original had them
        if [[ -n "$orig_tags" ]]; then
          cmd_parts+=($orig_tags)
        fi

        # Add due date offset
        cmd_parts+=("due:${i}${interval}")

        # Add dependency on previous subtask
        if [[ -n "$prev_id" ]]; then
          cmd_parts+=("depends:$prev_id")
        fi

        local result
        result=$(task rc.confirmation=no "${cmd_parts[@]}" 2>&1)
        # Extract the new task ID
        local new_id
        new_id=$(echo "$result" | grep -o 'Created task [0-9]*' | grep -o '[0-9]*')
        if [[ -z "$new_id" ]]; then
          new_id=$(task rc.confirmation=no +LATEST ids 2>/dev/null | tr -d ' ')
        fi

        created_ids+=("$new_id")
        prev_id="$new_id"
        echo "  ✓ $prefix $i: task $new_id (due: +${i}${interval}${prev_id:+, depends: $prev_id})"
      done

      echo ""
      log_success "Created ${#created_ids[@]} subtasks: ${created_ids[*]}"
      ;;
  esac
}

# ============================================================================
# GUN COMMAND
# ============================================================================

cmd_gun() {
  local subcommand="${1:-}"
  shift 2>/dev/null || true

  # Upstream: https://github.com/hamzamohdzubair/taskgun
  # Author: hamzamohdzubair · MIT License · Rust

  case "$subcommand" in
    install)
      if command -v taskgun &>/dev/null; then
        log_success "taskgun already installed: $(taskgun --version 2>/dev/null || echo 'version unknown')"
        return 0
      fi
      if command -v cargo &>/dev/null; then
        echo "Installing taskgun via cargo..."
        echo "  Upstream: https://github.com/hamzamohdzubair/taskgun"
        echo "  Author:   hamzamohdzubair · MIT License"
        cargo install taskgun
        log_success "taskgun installed"
      elif command -v brew &>/dev/null; then
        echo "Trying brew install taskgun..."
        brew install taskgun 2>/dev/null || {
          log_error "taskgun not available via brew. Install cargo first:"
          echo "  brew install rust" >&2
          echo "  cargo install taskgun" >&2
          exit 1
        }
      else
        log_error "Neither cargo nor brew found"
        echo "Install cargo: https://rustup.rs/" >&2
        echo "Then: cargo install taskgun" >&2
        exit 1
      fi
      ;;
    create)
      if [[ -z "${TASKRC:-}" || -z "${TASKDATA:-}" ]]; then
        log_error "No active profile — activate one first: p-<profile-name>"
        exit 1
      fi
      if ! command -v taskgun &>/dev/null; then
        log_error "taskgun not installed — run: ww gun install"
        exit 1
      fi
      TASKRC="${TASKRC}" TASKDATA="${TASKDATA}" taskgun create "$@"
      ;;
    help|-h|--help)
      cat << 'EOF'
Gun Command — Bulk Task Series Generator

Generates deadline-spaced task series from a single command.
Useful for book chapters, lecture series, practice sets.

Usage:
  ww gun create <project> -p <parts> -u <unit> [options]
  ww gun install              Install taskgun binary
  ww gun help                 Show this help

Options (passed to taskgun):
  -p <parts>          Number of parts (or comma-separated per-chapter counts)
  -u <unit>           Unit name (Lecture, Chapter, Exercise, etc.)
  --offset <duration> Start offset from now (2d, 1w, 2h, 30m)
  --interval <dur>    Interval between tasks (1d, 7d, 1h)
  --skip <preset>     Skip rule: weekend, bedtime, or custom (2200-0600, mon,wed)

Examples:
  ww gun create ML_Course -p 10 -u Lecture --offset 2d --interval 1d
  ww gun create CLRS -p 12 -u Chapter --offset 7d --interval 7d --skip weekend
  ww gun create Exam_Prep -p 30 -u Lecture --offset 2h --interval 2h --skip bedtime
  ww gun create Design_Patterns -p 3,4,2 -u Section --offset 3d --interval 3d

Note: project names with spaces must use underscores.
  Use: Design_Patterns
  Not: "Design Patterns" (TaskWarrior splits on spaces)

All ww gun create flags pass through to taskgun unchanged.
Run 'taskgun create --help' for the full flag reference.

Powered by taskgun · hamzamohdzubair
  https://github.com/hamzamohdzubair/taskgun · MIT License
EOF
      ;;
    "")
      cmd_gun help
      ;;
    *)
      # Pass all other subcommands through to taskgun directly
      if [[ -z "${TASKRC:-}" || -z "${TASKDATA:-}" ]]; then
        log_error "No active profile — activate one first: p-<profile-name>"
        exit 1
      fi
      if ! command -v taskgun &>/dev/null; then
        log_error "taskgun not installed — run: ww gun install"
        exit 1
      fi
      TASKRC="${TASKRC}" TASKDATA="${TASKDATA}" taskgun "${subcommand}" "$@"
      ;;
  esac
}

# ============================================================================
# TUI COMMAND
# ============================================================================

cmd_tui() {
  local subcommand="${1:-}"

  case "$subcommand" in
    install)
      if command -v taskwarrior-tui &>/dev/null; then
        local ver
        ver=$(taskwarrior-tui --version 2>/dev/null | head -1 || echo "unknown")
        log_success "taskwarrior-tui already installed: $ver"
      else
        if command -v brew &>/dev/null; then
          echo "Installing taskwarrior-tui via brew ..."
          brew install taskwarrior-tui
          log_success "taskwarrior-tui installed"
        elif command -v cargo &>/dev/null; then
          echo "Installing taskwarrior-tui via cargo ..."
          cargo install taskwarrior-tui
          log_success "taskwarrior-tui installed"
        else
          # Detect platform and emit appropriate hint -- do not auto-install on Linux
          local _tui_pm
          if command -v apt &>/dev/null; then
            _tui_pm="apt"
          elif command -v dnf &>/dev/null; then
            _tui_pm="dnf"
          elif command -v pacman &>/dev/null; then
            _tui_pm="pacman"
          else
            _tui_pm="unknown"
          fi
          log_error "taskwarrior-tui not found and no auto-install path available"
          echo "Install options:"
          case "$_tui_pm" in
            apt)
              echo "  cargo: cargo install taskwarrior-tui  (recommended on Debian/Ubuntu)"
              echo "  snap:  snap install taskwarrior-tui"
              ;;
            dnf)
              echo "  cargo: cargo install taskwarrior-tui  (recommended on Fedora/RHEL)"
              ;;
            pacman)
              echo "  pacman: sudo pacman -S taskwarrior-tui  (AUR: yay -S taskwarrior-tui)"
              echo "  cargo:  cargo install taskwarrior-tui"
              ;;
            *)
              echo "  brew:  brew install taskwarrior-tui"
              echo "  cargo: cargo install taskwarrior-tui"
              echo "  snap:  snap install taskwarrior-tui"
              ;;
          esac
          exit 1
        fi
      fi
      ;;
    help|-h|--help)
      cat << 'EOF'
TUI Command

Launch an interactive terminal UI for task management.

Usage:
  ww tui              Launch TUI (requires active profile)
  ww tui install      Check / install taskwarrior-tui binary
  ww tui help         Show this help

All task operations run against the active profile's data.
Profile isolation is automatic — TASKRC and TASKDATA are scoped.

Powered by taskwarrior-tui · Karthikeyan Singaravelan (@kdheepak)
  https://github.com/kdheepak/taskwarrior-tui · MIT License
EOF
      ;;
    "")
      if [[ -z "${TASKRC:-}" || -z "${TASKDATA:-}" ]]; then
        log_error "No active profile — activate one first: p-<profile-name>"
        exit 1
      fi
      if ! command -v taskwarrior-tui &>/dev/null; then
        log_error "taskwarrior-tui not installed"
        echo "Install it: ww tui install"
        exit 1
      fi
      # Attribution visible in scroll buffer once TUI exits (alt-screen restore)
      echo "taskwarrior-tui · @kdheepak · MIT · github.com/kdheepak/taskwarrior-tui"
      exec taskwarrior-tui --taskrc "$TASKRC" --taskdata "$TASKDATA"
      ;;
    *)
      log_error "Unknown tui subcommand: $subcommand"
      echo "Run 'ww tui help' for usage"
      exit 1
      ;;
  esac
}

# ============================================================================
# MCP COMMAND
# ============================================================================

cmd_mcp() {
  local subcommand="${1:-}"
  shift 2>/dev/null || true

  # Upstream: https://github.com/hnsstrk/taskwarrior-mcp
  # Author: hnsstrk · MIT License · Python
  local MCP_INSTALL_DIR="$HOME/.local/share/ww/mcp/taskwarrior"
  local MCP_BINARY="taskwarrior-mcp"

  case "$subcommand" in
    install)
      if command -v "$MCP_BINARY" &>/dev/null; then
        log_success "$MCP_BINARY already installed: $(${MCP_BINARY} --version 2>/dev/null || echo 'version unknown')"
        return 0
      fi
      if ! command -v uv &>/dev/null; then
        if command -v brew &>/dev/null; then
          echo "Installing uv (required for taskwarrior-mcp) via brew ..."
          brew install uv
        else
          # Detect platform and emit appropriate hint -- do not auto-install on Linux
          local _mcp_pm
          if command -v apt &>/dev/null; then
            _mcp_pm="apt"
          elif command -v dnf &>/dev/null; then
            _mcp_pm="dnf"
          elif command -v pacman &>/dev/null; then
            _mcp_pm="pacman"
          else
            _mcp_pm="unknown"
          fi
          log_error "uv not found and no auto-install path available"
          echo "Install uv first, then re-run 'ww mcp install':" >&2
          case "$_mcp_pm" in
            apt)
              echo "  curl -LsSf https://astral.sh/uv/install.sh | sh   (Debian/Ubuntu)" >&2
              echo "  or: pip install uv" >&2
              ;;
            dnf)
              echo "  curl -LsSf https://astral.sh/uv/install.sh | sh   (Fedora/RHEL)" >&2
              echo "  or: pip install uv" >&2
              ;;
            pacman)
              echo "  sudo pacman -S uv   (Arch/Manjaro)" >&2
              echo "  or: curl -LsSf https://astral.sh/uv/install.sh | sh" >&2
              ;;
            *)
              echo "  https://docs.astral.sh/uv/" >&2
              ;;
          esac
          exit 1
        fi
      fi
      echo "Installing taskwarrior-mcp from hnsstrk/taskwarrior-mcp …"
      echo "  Upstream: https://github.com/hnsstrk/taskwarrior-mcp"
      echo "  Author:   hnsstrk · MIT License"
      mkdir -p "$(dirname "$MCP_INSTALL_DIR")"
      if [[ -d "$MCP_INSTALL_DIR" ]]; then
        echo "  Updating existing clone …"
        git -C "$MCP_INSTALL_DIR" pull --quiet
      else
        git clone --quiet https://github.com/hnsstrk/taskwarrior-mcp.git "$MCP_INSTALL_DIR"
      fi
      uv tool install -e "$MCP_INSTALL_DIR/mcp-server"
      if command -v "$MCP_BINARY" &>/dev/null; then
        log_success "taskwarrior-mcp installed"
        echo ""
        echo "Next: register with your MCP client:"
        echo "  ww mcp register"
      else
        log_error "Installation completed but $MCP_BINARY not found on PATH"
        echo "Check that uv's bin directory is on your PATH" >&2
        exit 1
      fi
      ;;
    register)
      local scope="user"
      for arg in "$@"; do
        case "$arg" in
          --scope) ;;
          user|project|local) scope="$arg" ;;
        esac
      done
      if [[ -z "${TASKRC:-}" || -z "${TASKDATA:-}" ]]; then
        log_error "No active profile — activate one first: p-<profile-name>"
        echo "Profile env vars (TASKRC, TASKDATA) must be set for registration." >&2
        exit 1
      fi
      if ! command -v "$MCP_BINARY" &>/dev/null; then
        log_error "$MCP_BINARY not installed — run: ww mcp install"
        exit 1
      fi
      local register_cmd="claude mcp add --transport stdio --scope ${scope} taskwarrior"
      register_cmd+=' --env TW_MCP_TASKRC="$TASKRC"'
      register_cmd+=' --env TW_MCP_TASK_DATA="$TASKDATA"'
      register_cmd+=" -- $MCP_BINARY"
      if command -v claude &>/dev/null; then
        echo "Registering taskwarrior-mcp with Claude Code (scope: ${scope}) …"
        echo "  Profile: ${WARRIOR_PROFILE:-active}"
        echo "  TASKRC:  $TASKRC"
        echo "  TASKDATA: $TASKDATA"
        claude mcp add --transport stdio --scope "${scope}" taskwarrior \
          --env "TW_MCP_TASKRC=${TASKRC}" \
          --env "TW_MCP_TASK_DATA=${TASKDATA}" \
          -- "$MCP_BINARY"
        log_success "Registered. Restart Claude Code to activate."
      else
        echo "claude CLI not found — manual registration command:"
        echo ""
        echo "  $register_cmd"
        echo ""
        echo "For other MCP clients, configure with:"
        echo "  command: $MCP_BINARY"
        echo "  env:     TW_MCP_TASKRC=$TASKRC"
        echo "           TW_MCP_TASK_DATA=$TASKDATA"
      fi
      ;;
    status)
      echo "taskwarrior-mcp status"
      echo ""
      if command -v "$MCP_BINARY" &>/dev/null; then
        local ver
        ver=$("$MCP_BINARY" --version 2>/dev/null || echo "unknown")
        echo "  installed:  yes ($ver)"
        echo "  binary:     $(command -v "$MCP_BINARY")"
        echo "  source:     $MCP_INSTALL_DIR"
      else
        echo "  installed:  no"
        echo "  install:    ww mcp install"
      fi
      echo ""
      if [[ -n "${TASKRC:-}" && -n "${TASKDATA:-}" ]]; then
        echo "  active profile: ${WARRIOR_PROFILE:-unknown}"
        echo "  TW_MCP_TASKRC:      $TASKRC"
        echo "  TW_MCP_TASK_DATA:   $TASKDATA"
      else
        echo "  active profile: none (activate with p-<profile-name>)"
      fi
      echo ""
      if command -v claude &>/dev/null; then
        echo "  claude CLI: available"
        echo "  register:   ww mcp register [--scope user|project]"
      else
        echo "  claude CLI: not found (manual registration required)"
      fi
      ;;
    help|-h|--help)
      cat << 'EOF'
MCP Command — TaskWarrior MCP Server

Exposes TaskWarrior to any MCP-capable AI agent (Claude Code, Amazon Q, Gemini, etc.)
with full ww profile isolation. Profile scoping is automatic via TASKRC/TASKDATA.

Usage:
  ww mcp install              Install taskwarrior-mcp server
  ww mcp register [--scope]   Register with MCP client (scope: user|project, default: user)
  ww mcp status               Show install and registration status
  ww mcp help                 Show this help

Profile isolation:
  When a ww profile is active, TASKRC and TASKDATA are set automatically.
  The MCP server reads TW_MCP_TASKRC and TW_MCP_TASK_DATA — same values.
  Each profile gets its own isolated task database via the MCP server.

AI agent usage:
  Once registered, any MCP client can manage tasks in the active profile:
    "What are my open tasks?"
    "Create a task 'Review PR #42' with high priority, due Friday"
    "Mark task a1b2c3d4 as done"

Powered by taskwarrior-mcp · hnsstrk
  https://github.com/hnsstrk/taskwarrior-mcp · MIT License
EOF
      ;;
    "")
      cmd_mcp status
      ;;
    *)
      log_error "Unknown mcp subcommand: $subcommand"
      echo "Run 'ww mcp help' for usage"
      exit 1
      ;;
  esac
}

# ============================================================================
# BROWSER COMMAND
# ============================================================================

cmd_browser() {
  # Delegate entirely to services/browser/browser.sh.
  # Modeled on cmd_tui() / cmd_mcp(): check prerequisites, then exec.

  if ! command -v python3 &>/dev/null; then
    log_error "python3 not found — required by ww browser"
    echo "Install Python 3: https://www.python.org/downloads/" >&2
    exit 1
  fi

  local browser_sh="${WW_BASE}/services/browser/browser.sh"
  if [[ ! -f "$browser_sh" ]]; then
    log_error "browser service not found at ${browser_sh}"
    exit 2
  fi

  bash "$browser_sh" "$@"
}

# ============================================================================
# ISSUES UDA HELPERS
# ============================================================================

_issues_uda_install() {
    # Idempotently install bugwarrior UDAs into the active profile's .taskrc.
    # Runs `bugwarrior uda`, then appends only lines not already present.
    if ! command -v bugwarrior &>/dev/null; then
        log_error "bugwarrior is not installed"
        echo "Install with: pipx install bugwarrior && pipx inject bugwarrior setuptools" >&2
        exit 1
    fi

    local taskrc="${WORKWARRIOR_BASE}/.taskrc"
    local bugwarrior_config="${WORKWARRIOR_BASE}/.config/bugwarrior/bugwarriorrc"
    [[ -f "${WORKWARRIOR_BASE}/.config/bugwarrior/bugwarrior.toml" ]] && \
        bugwarrior_config="${WORKWARRIOR_BASE}/.config/bugwarrior/bugwarrior.toml"

    local bw_udas
    if ! bw_udas=$(BUGWARRIORRC="${bugwarrior_config}" bugwarrior uda 2>/dev/null); then
        log_error "bugwarrior uda failed — is bugwarrior configured? Run: ww issues custom"
        exit 1
    fi

    local added=0 skipped=0
    while IFS= read -r line; do
        [[ -z "${line}" || "${line}" =~ ^# ]] && continue
        local key="${line%%=*}"
        if grep -q "^${key}=" "${taskrc}" 2>/dev/null; then
            skipped=$(( skipped + 1 ))
        else
            echo "${line}" >> "${taskrc}"
            added=$(( added + 1 ))
        fi
    done <<< "${bw_udas}"

    echo "✓ UDA install complete: ${added} added, ${skipped} already present"
}

_issues_uda_group() {
    # Create or update a UDA group in .taskrc for a known service prefix.
    local svc_name="$1"
    local taskrc="${WORKWARRIOR_BASE}/.taskrc"

    local prefix
    case "${svc_name}" in
        github)  prefix="github" ;;
        gitlab)  prefix="gitlab" ;;
        jira)    prefix="jira" ;;
        trello)  prefix="trello" ;;
        sync)    prefix="sync" ;;
        *)
            log_error "Unknown service '${svc_name}'. Known: github gitlab jira trello sync"
            exit 1 ;;
    esac

    local uda_list
    uda_list=$(grep -E "^uda\\.${prefix}[^.]+\\.type=" "${taskrc}" 2>/dev/null \
        | awk -F. '{print $2}' | sort -u | tr '\n' ',' | sed 's/,$//' || true)

    if [[ -z "${uda_list}" ]]; then
        log_error "No ${svc_name} UDAs found in .taskrc. Run: ww issues uda install"
        exit 1
    fi

    local group_line="# group:${svc_name} udas:${uda_list}"

    if grep -q "^# === WW UDA GROUPS ===" "${taskrc}" 2>/dev/null; then
        if grep -q "^# group:${svc_name} " "${taskrc}" 2>/dev/null; then
            sed -i.bak "s|^# group:${svc_name} .*|${group_line}|" "${taskrc}" \
                && rm -f "${taskrc}.bak"
        else
            sed -i.bak "/^# === END WW UDA GROUPS ===/i\\
${group_line}" "${taskrc}" && rm -f "${taskrc}.bak"
        fi
    else
        printf '\n# === WW UDA GROUPS ===\n%s\n# === END WW UDA GROUPS ===\n' \
            "${group_line}" >> "${taskrc}"
    fi

    local count
    count=$(echo "${uda_list}" | tr ',' '\n' | wc -l | tr -d ' ')
    echo "✓ Group '${svc_name}' written — ${count} UDAs: ${uda_list}"
}

# ============================================================================
# ISSUES COMMAND
# ============================================================================

cmd_issues() {
  # Parse all args: first non-flag is the subcommand; strip --json from remaining
  local json_mode=0
  local subcommand=""
  local remaining=()
  for arg in "$@"; do
    if [[ "$arg" == "--json" ]]; then
      json_mode=1
    elif [[ -z "$subcommand" && "$arg" != --* ]]; then
      subcommand="$arg"
    else
      remaining+=("$arg")
    fi
  done
  set -- "${remaining[@]+"${remaining[@]}"}"

  case "$subcommand" in
    ""|help|--help|-h)
      cat << 'EOF'
Issues Service

Routes to bugwarrior (one-way pull) or github-sync (two-way):

  ww issues pull [--dry-run] [--json]              Pull issues from all configured services
  ww issues uda list                                List UDAs grouped by source service
  ww issues uda install                             Install missing bugwarrior UDAs (idempotent)
  ww issues uda group <service>                     Create UDA group (github gitlab jira trello sync)

  ww issues push [task-id]                          Push task changes to GitHub
  ww issues sync [task-id]                          Bidirectional sync with GitHub
  ww issues enable-sync <task-id> <issue> <repo>    Enable GitHub sync for a task
  ww issues disable-sync <task-id>                  Disable GitHub sync for a task
  ww issues status [--json]                         Show GitHub sync status

  ww issues custom                                  Configure issue services interactively
  ww issues help                                    Show this help

Note: 'ww issues' and 'i' are synonymous.
Requires an active profile: p-<profile-name>

Bugwarrior is one-way only (external services → TaskWarrior).
For two-way GitHub sync, use: ww issues push / sync / enable-sync

EOF
      ;;
    custom)
      if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
        log_error "Issues service requires an active profile"
        echo "Activate a profile with: p-<profile-name>" >&2
        exit 1
      fi
      WORKWARRIOR_BASE="$WORKWARRIOR_BASE" WARRIOR_PROFILE="$WARRIOR_PROFILE" \
        "$WW_BASE/services/custom/configure-issues.sh" "$@"
      ;;
    push|sync|enable-sync|enable|disable-sync|disable|status|sync-status)
      if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
        log_error "Issues service requires an active profile"
        echo "Activate a profile with: p-<profile-name>" >&2
        exit 1
      fi
      local github_sync_cli="$WW_BASE/services/custom/github-sync.sh"
      if [[ ! -f "$github_sync_cli" ]]; then
        log_error "GitHub sync CLI not found at $github_sync_cli"
        exit 1
      fi
      local sync_command
      case "$subcommand" in
        enable-sync|enable) sync_command="enable" ;;
        disable-sync|disable) sync_command="disable" ;;
        sync-status|status) sync_command="status" ;;
        *) sync_command="$subcommand" ;;
      esac
      if [[ "$sync_command" == "status" && "$json_mode" -eq 1 ]]; then
        local sync_output sync_exit=0
        sync_output=$(WORKWARRIOR_BASE="$WORKWARRIOR_BASE" WARRIOR_PROFILE="$WARRIOR_PROFILE" \
          "$github_sync_cli" "$sync_command" "$@" 2>&1) || sync_exit=$?
        local escaped="${sync_output//\\/\\\\}"
        escaped="${escaped//\"/\\\"}"
        escaped="${escaped//$'\n'/\\n}"
        if [[ "$sync_exit" -eq 0 ]]; then
          echo "{\"command\":\"status\",\"status\":\"success\",\"output\":\"${escaped}\"}"
        else
          echo "{\"command\":\"status\",\"status\":\"failed\",\"exit_code\":${sync_exit},\"output\":\"${escaped}\"}"
        fi
        exit "$sync_exit"
      fi
      WORKWARRIOR_BASE="$WORKWARRIOR_BASE" WARRIOR_PROFILE="$WARRIOR_PROFILE" \
        "$github_sync_cli" "$sync_command" "$@"
      ;;
    uda)
      local uda_sub="${1:-list}"; shift || true
      local uda_script="$WW_BASE/services/profile/subservices/profile-uda.sh"
      case "$uda_sub" in
        help|--help|-h)
          cat << 'EOF'
ww issues uda — manage service UDAs

  ww issues uda list              List all UDAs grouped by source service
  ww issues uda install           Install missing bugwarrior UDAs (idempotent)
  ww issues uda group <service>   Create UDA group for a service (github gitlab jira trello sync)
  ww issues uda help              Show this help

For full UDA management use: ww profile uda
EOF
          ;;
        ""|list)
          if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
            log_error "Issues service requires an active profile"
            echo "Activate a profile with: p-<profile-name>" >&2; exit 1
          fi
          if [[ ! -f "$uda_script" ]]; then
            log_error "UDA service not found at $uda_script"; exit 1
          fi
          WORKWARRIOR_BASE="${WORKWARRIOR_BASE}" WARRIOR_PROFILE="${WARRIOR_PROFILE:-}" \
            bash "$uda_script" list
          ;;
        install)
          if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
            log_error "Issues service requires an active profile"
            echo "Activate a profile with: p-<profile-name>" >&2; exit 1
          fi
          _issues_uda_install
          ;;
        group)
          local svc_arg="${1:-}"
          if [[ -z "$svc_arg" ]]; then
            log_error "Usage: ww issues uda group <service>  (github gitlab jira trello sync)"
            exit 1
          fi
          if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
            log_error "Issues service requires an active profile"
            echo "Activate a profile with: p-<profile-name>" >&2; exit 1
          fi
          _issues_uda_group "$svc_arg"
          ;;
        *)
          log_error "Unknown subcommand: ww issues uda ${uda_sub}"
          echo "Run 'ww issues uda help' for usage." >&2; exit 1
          ;;
      esac
      ;;
    pull|*)
      if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
        log_error "Issues service requires an active profile"
        echo "Activate a profile with: p-<profile-name>" >&2
        exit 1
      fi
      local bugwarrior_config="$WORKWARRIOR_BASE/.config/bugwarrior/bugwarriorrc"
      if [[ ! -f "$bugwarrior_config" ]]; then
        bugwarrior_config="$WORKWARRIOR_BASE/.config/bugwarrior/bugwarrior.toml"
        if [[ ! -f "$bugwarrior_config" ]]; then
          log_error "Bugwarrior configuration not found"
          echo "Run 'ww issues custom' to configure the issues service" >&2
          exit 1
        fi
      fi
      if ! command -v bugwarrior &>/dev/null; then
        log_error "bugwarrior is not installed"
        echo "Install with: pipx install bugwarrior && pipx inject bugwarrior setuptools" >&2
        exit 1
      fi
      if [[ "$subcommand" == "pull" && "$json_mode" -eq 0 ]]; then
        echo "⚠️  One-way sync: External services → TaskWarrior"
        echo "   Changes in TaskWarrior will NOT sync back to issue trackers"
        echo "   For two-way GitHub sync, use: ww issues push / sync / enable-sync"
        echo ""
      fi
      if [[ "$json_mode" -eq 1 ]]; then
        local bw_exit=0
        BUGWARRIORRC="$bugwarrior_config" \
        BUGWARRIOR_TASKRC="$WORKWARRIOR_BASE/.taskrc" \
        BUGWARRIOR_TASKDATA="$WORKWARRIOR_BASE/.task" \
          bugwarrior "$subcommand" "$@" >/dev/null 2>&1 || bw_exit=$?
        if [[ "$bw_exit" -eq 0 ]]; then
          echo "{\"command\":\"${subcommand}\",\"status\":\"success\"}"
        else
          echo "{\"command\":\"${subcommand}\",\"status\":\"failed\",\"exit_code\":${bw_exit}}"
        fi
        exit "$bw_exit"
      fi
      BUGWARRIORRC="$bugwarrior_config" \
      BUGWARRIOR_TASKRC="$WORKWARRIOR_BASE/.taskrc" \
      BUGWARRIOR_TASKDATA="$WORKWARRIOR_BASE/.task" \
        bugwarrior "$subcommand" "$@"
      ;;
  esac
}

# ============================================================================
# MAIN DISPATCHER
# ============================================================================

main() {
  parse_global_flags "$@"
  set -- "${WW_MAIN_ARGS[@]}"
  local command="${1:-}"
  shift 2>/dev/null || true

  export WW_OUTPUT_MODE
  export WW_VERBOSE

  if [[ $WW_FLAG_HELP -eq 1 ]]; then
    if [[ -n "$command" ]]; then
      show_service_help "$command"
    else
      show_usage
    fi
    return 0
  fi

  resolve_scope_context

  case "$command" in
    profile|p)
      cmd_profile "$@"
      ;;
    profiles)
      cmd_profile list "$@"
      ;;
    service|s)
      cmd_service "$@"
      ;;
    services)
      if [[ $# -eq 0 ]]; then
        cmd_service list
      else
        cmd_service "$@"
      fi
      ;;
    group)
      cmd_group "$@"
      ;;
    groups)
      if [[ $# -eq 0 ]]; then
        cmd_group list
      else
        cmd_group "$@"
      fi
      ;;
    model)
      cmd_models "$@"
      ;;
    models)
      if [[ $# -eq 0 ]]; then
        cmd_models list
      else
        cmd_models "$@"
      fi
      ;;
    journal)
      cmd_journal "$@"
      ;;
    journals)
      if [[ $# -eq 0 ]]; then
        cmd_journal list
      else
        cmd_journal "$@"
      fi
      ;;
    ledger)
      cmd_ledger "$@"
      ;;
    ledgers)
      if [[ $# -eq 0 ]]; then
        cmd_ledger list
      else
        cmd_ledger "$@"
      fi
      ;;
    ctrl)
      cmd_ctrl "$@"
      ;;
    extensions)
      cmd_extensions "$@"
      ;;
    find)
      cmd_find "$@"
      ;;
    tui)
      cmd_tui "$@"
      ;;
    gun)
      cmd_gun "$@"
      ;;
    sword)
      cmd_sword "$@"
      ;;
    remove)
      bash "$WW_BASE/services/remove/remove.sh" "$@"
      ;;
    compile-heuristics)
      python3 "$WW_BASE/scripts/compile-heuristics.py" --ww-base "$WW_BASE" "$@"
      ;;
    next)
      cmd_next "$@"
      ;;
    schedule)
      cmd_schedule "$@"
      ;;
    mcp)
      cmd_mcp "$@"
      ;;
    browser)
      cmd_browser "$@"
      ;;
    issues)
      cmd_issues "$@"
      ;;
    custom)
      cmd_custom "$@"
      ;;
    q|questions)
      cmd_questions "$@"
      ;;
    shortcut)
      cmd_shortcut "$@"
      ;;
    export|e)
      if [[ -f "$WW_BASE/services/export/export.sh" ]]; then
        "$WW_BASE/services/export/export.sh" "$@"
      else
        log_error "Export service not found"
        exit 1
      fi
      ;;
    x)
      if [[ -f "$WW_BASE/services/x-delete/x.sh" ]]; then
        "$WW_BASE/services/x-delete/x.sh" "$@"
      else
        log_error "Delete service not found"
        exit 1
      fi
      ;;
    deps|d)
      cmd_deps "$@"
      ;;
    version|--version|-v)
      show_version
      ;;
    help|--help|-h|"")
      if [[ -n "${1:-}" ]]; then
        show_service_help "$1"
      else
        show_usage
      fi
      ;;
    *)
      log_error "Unknown command: $command"
      echo ""
      echo "Run 'ww help' for usage"
      exit 1
      ;;
  esac
}

main "$@"
