#!/usr/bin/env bash
# Workwarrior CLI Entry Point
# Usage: ww <command> [arguments]

set -euo pipefail

# ============================================================================
# CONFIGURATION
# ============================================================================

WW_BASE="${WW_BASE:-$HOME/ww}"
WW_VERSION="1.0.0"
WW_OUTPUT_MODE="human"
WW_VERBOSE=0
WW_FLAG_PROFILE=""
WW_FLAG_GLOBAL=0
WW_FLAG_JSON=0
WW_FLAG_COMPACT=0
WW_FLAG_HELP=0
WW_MAIN_ARGS=()

# ============================================================================
# SOURCE LIBRARIES
# ============================================================================

if [[ -f "$WW_BASE/lib/core-utils.sh" ]]; then
  source "$WW_BASE/lib/core-utils.sh"
else
  # Fallback logging if core-utils not available
  log_info() { echo "info $*"; }
  log_success() { echo "ok $*"; }
  log_warning() { echo "warn $*"; }
  log_error() { echo "err $*" >&2; }
  log_step() { echo ">> $*"; }
  log_deprecation() { echo "deprecated $*" >&2; }
fi

if [[ -f "$WW_BASE/lib/profile-manager.sh" ]]; then
  source "$WW_BASE/lib/profile-manager.sh"
fi

# ============================================================================
# HELP AND VERSION
# ============================================================================

show_usage() {
  cat << EOF
Workwarrior - Profile-based productivity system

Usage: ww <command> [arguments]
       ww [--profile <name> | --global] [--json|--compact] [--verbose] <command> [arguments]
       ww help <command>

Commands:
  profile     Profile management (create, list, info, delete, backup)
  profiles    List profiles (shortcut for 'ww profile list')
  service     Service management (list, info, help)
  services    List services (shortcut for 'ww service list')
  group       Preferred group namespace (create, list, add, remove, show, delete)
  groups      Alias for group namespace (bare form lists groups)
  model       Preferred model namespace (providers and model registry)
  models      Alias for model namespace (bare form lists models)
  journal     Preferred journal namespace (add, list, remove, rename)
  journals    Alias for journal namespace (bare form lists journals)
  ledger      Preferred ledger namespace (add, list, remove, rename)
  ledgers     Alias for ledger namespace (bare form lists ledgers)
  extensions  External tool extensions registry
  find        Search across profiles and data types
  custom      Custom services (journal configuration, etc.)
  shortcut    Shortcut reference (list, info, compact)
  export      Export profile data (json, csv, markdown)
  x           Delete profiles and data (with backup)
  deps        Dependency management (check, install)
  version     Show version information
  help        Show this help message

Global Options:
  --profile <name>  Override active/last profile for this invocation
  --global          Force global context (no profile scope)
  --json            Machine-readable output for supported list/read commands
  --compact         Terse human-readable output
  --verbose         Expanded human-readable output
  --help            Show command usage (same as 'ww help')

Compatibility:
  Plural command aliases remain supported (`groups`, `models`, `journals`, `ledgers`,
  plus `profiles` and `services`) and emit a nudge toward preferred singular syntax.

Profile Commands:
  ww profile create <name>    Create a new profile
  ww profile list             List all profiles
  ww profile info <name>      Show profile details
  ww profile delete <name>    Delete a profile
  ww profile backup <name>    Backup a profile

Service Commands:
  ww service list             List available service categories
  ww service info <name>      Show category details and usage hints
  ww service help <name>      Route to detailed help for a category/topic

Groups Commands:
  ww group list                List all groups
  ww groups                    List all groups (shortcut)
  ww group show <name>         Show profiles in a group
  ww group create <name> [profiles...]
  ww group add <name> <profiles...>
  ww group remove <name> <profiles...>
  ww group delete <name>

Models Commands:
  ww model list                List models and default
  ww models                    List models and default (shortcut)
  ww model providers           List model providers
  ww model env                 Show provider environment variables
  ww model check               Check required env vars
  ww model show <model>        Show model details
  ww model add-provider <name> <type> <base_url> [api_key_env]
  ww model add-model <name> <provider> <model_id> [notes]
  ww model set-default <name>
  ww model remove-model <name>

Journal Commands:
  ww journal add <name>        Add journal to active profile
  ww journal list              List journals in active profile
  ww journal remove <name>     Remove journal from active profile
  ww journal rename <old> <new> Rename journal in active profile
  ww journals                  Same as 'ww journal list'

Ledger Commands:
  ww ledger add <name>         Add ledger to active profile
  ww ledger list               List ledgers in active profile
  ww ledger remove <name>      Remove ledger from active profile
  ww ledger rename <old> <new> Rename ledger in active profile
  ww ledgers                   Same as 'ww ledger list'

Extensions Commands:
  ww extensions taskwarrior refresh
  ww extensions taskwarrior list --status active
  ww extensions taskwarrior search vim
  ww extensions taskwarrior info taskwiki
  ww extensions taskwarrior cards

Find Commands:
  ww find <term>               Search across profiles
  ww find --type journal <t>   Search a specific data type
  ww find --profile <name> <t> Search a specific profile
  ww find --query <expr>       Advanced query syntax
  ww find --case-sensitive <t> Case-sensitive matching
  ww find --regex <t>          Treat bare terms as regex
  ww find --exclude <glob> <t> Exclude matching paths (repeatable)
  ww find --native <t>         Use native tool search where available

Custom Services:
  ww custom journals          Configure journal settings (requires active profile)
  ww custom tasks             Configure TaskWarrior settings (requires active profile)
  ww custom times             Configure TimeWarrior settings (requires active profile)
  ww custom ledgers           Configure ledger settings (requires active profile)
  ww custom list              List available custom services

Shortcut Commands:
  ww shortcut list            List available shortcuts
  ww shortcut list <category> List shortcuts in a category
  ww shortcut info <key>      Show shortcut details
  ww shortcut compact         Compact shortcut list
  ww shortcut add <key> <name> <category> <description> <command> [requires_profile]
  ww shortcut remove <key>    Remove user shortcut override

Dependency Commands:
  ww deps check               Check installed dependencies
  ww deps install             Install missing dependencies

Examples:
  ww profile create work      Create a profile named 'work'
  ww profile list             Show all profiles
  ww --profile work journal list
  ww --json service list
  ww --compact profile list
  ww group create focus work personal
  ww groups                   List groups (shortcut)
  ww model list
  ww models                   List models (shortcut)
  ww extensions taskwarrior list --status active
  ww find invoice
  extensions taskwarrior list --status active
  models
  groups
  journals
  ledgers
  find
  services
  ww deps check               Check dependency status
  ww version                  Show version
  ww help groups              Show groups help
  ww help models              Show models help
  ww help find                Show find help
  ww shortcut list            Show available shortcuts
  ww shortcut info <key>      Show details for a shortcut
  ww shortcut add x "Example" global "Example command" "echo hi" false
  ww shortcut remove x

Standalone Commands:
  extensions     Alias for 'ww extensions'
  models         Alias for 'ww model list'
  groups         Alias for 'ww group list'
  journals       List journals for active profile
  ledgers        List ledgers for active profile
  find           Alias for 'ww find'
  services       Alias for 'ww service'
  tasks          Alias for 'task'
  times          Alias for 'timew'

After creating a profile, activate it with:
  p-<profile-name>            e.g., p-work

For more information, see: $WW_BASE/docs/

EOF
}

show_help_profile() {
  cat << EOF
Profile Management

Usage: ww profile <action> [arguments]

Actions:
  create <name>              Create a new profile
  list                       List all profiles
  info <name>                Show profile details
  delete <name>              Delete a profile
  backup <name> [dest]       Backup a profile to tar.gz
  import <archive> [name]    Create a new profile from a backup archive
  restore <name> <archive>   Replace an existing profile from a backup archive
  urgency [subcommand]       Manage urgency coefficients for the active profile
  uda [subcommand]           Manage UDAs for the active profile
  udas                       Alias for 'uda list'

Urgency Subcommands:
  urgency show               Show all coefficients and top task scores
  urgency set <factor> <v>   Set a coefficient (e.g. urgency set due 10.0)
  urgency tune               Interactive wizard — step through all factors
  urgency reset              Remove all ww-managed coefficients
  urgency explain <id>       Break down urgency score for a specific task

UDA Subcommands:
  uda list [--all]           List all UDAs (--all includes uncategorized)
  uda add [<name>]           Add a UDA (interactive wizard)
  uda remove <name>          Remove a UDA
  uda group <name> [group]   Assign UDA to a group
  uda perm <name> [tokens]   Show or set sync permissions

Global Options:
  --json           Supported for: list
  --compact        Supported for: list
  --verbose        Add detail where supported

Examples:
  ww profile create work
  ww profile list
  ww --json profile list
  ww profile info work
  ww profile backup work
  ww profile import work-backup-20260101.tar.gz
  ww profile import work-backup-20260101.tar.gz work-copy
  ww profile restore work work-backup-20260101.tar.gz
  ww profile urgency show
  ww profile urgency set uda.phase.review 5.0
  ww profile urgency explain 42
  ww profile uda list
  ww profile uda add goals
  ww profile uda perm goals nosync,noai
  ww profile udas
EOF
}

