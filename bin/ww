show_service_help() {
  local topic="${1:-}"
  case "$topic" in
    profile)
      show_help_profile
      ;;
    service|services)
      show_help_service
      ;;
    group|groups)
      if [[ "$topic" == "groups" ]]; then
        nudge_preferred_syntax "ww help groups" "ww help group"
      fi
      show_help_group
      ;;
    model|models)
      if [[ "$topic" == "models" ]]; then
        nudge_preferred_syntax "ww help models" "ww help model"
      fi
      show_help_model
      ;;
    journal|journals)
      if [[ "$topic" == "journals" ]]; then
        nudge_preferred_syntax "ww help journals" "ww help journal"
      fi
      show_help_journal
      ;;
    ledger|ledgers)
      if [[ "$topic" == "ledgers" ]]; then
        nudge_preferred_syntax "ww help ledgers" "ww help ledger"
      fi
      show_help_ledger
      ;;
    extensions)
      cmd_extensions help
      ;;
    find)
      cmd_find --help
      ;;
    custom)
      cmd_custom help
      ;;
    shortcut)
      cmd_shortcut help
      ;;
    deps)
      cmd_deps help
      ;;
    ""|help|-h|--help)
      show_usage
      ;;
    standalone)
      cat << EOF
Standalone Commands

These commands can be run without the ww prefix:
  extensions     Alias for 'ww extensions'
  models         Alias for 'ww model list'
  groups         Alias for 'ww group list'
  journals       List journals for active profile
  ledgers        List ledgers for active profile
  find           Alias for 'ww find'
  services       Alias for 'ww service'
  tasks          Alias for 'task'
  times          Alias for 'timew'
EOF
      ;;
    *)
      log_error "Unknown help topic: $topic"
      echo "Run 'ww help' for usage"
      exit 1
      ;;
  esac
}

show_version() {
  echo "Workwarrior version $WW_VERSION"
  echo "Installation: $WW_BASE"

  if [[ -f "$WW_BASE/VERSION" ]]; then
    local installed_version
    installed_version=$(cat "$WW_BASE/VERSION")
    if [[ "$installed_version" != "$WW_VERSION" ]]; then
      echo "Installed version: $installed_version"
    fi
  fi
}

print_json_array() {
  local items=("$@")
  local first=1
  printf '['
  for item in "${items[@]}"; do
    if [[ $first -eq 0 ]]; then
      printf ','
    fi
    first=0
    printf '"%s"' "$item"
  done
  printf ']'
}

nudge_preferred_syntax() {
  local legacy="$1"
  local preferred="$2"
  log_deprecation "'$legacy' still works; prefer '$preferred'"
}

parse_global_flags() {
  local args=("$@")

  while [[ ${#args[@]} -gt 0 ]]; do
    case "${args[0]}" in
      --profile)
        if [[ ${#args[@]} -lt 2 || -z "${args[1]}" ]]; then
          log_error "--profile requires a profile name"
          exit 1
        fi
        WW_FLAG_PROFILE="${args[1]}"
        args=("${args[@]:2}")
        ;;
      --global)
        WW_FLAG_GLOBAL=1
        args=("${args[@]:1}")
        ;;
      --json)
        WW_FLAG_JSON=1
        args=("${args[@]:1}")
        ;;
      --compact)
        WW_FLAG_COMPACT=1
        args=("${args[@]:1}")
        ;;
      --verbose)
        WW_VERBOSE=1
        args=("${args[@]:1}")
        ;;
      --help|-h)
        WW_FLAG_HELP=1
        args=("${args[@]:1}")
        ;;
      --)
        args=("${args[@]:1}")
        break
        ;;
      -*)
        break
        ;;
      *)
        break
        ;;
    esac
  done

  if [[ $WW_FLAG_GLOBAL -eq 1 && -n "$WW_FLAG_PROFILE" ]]; then
    log_error "Invalid flags: --profile and --global cannot be used together"
    exit 1
  fi
  if [[ $WW_FLAG_JSON -eq 1 && $WW_FLAG_COMPACT -eq 1 ]]; then
    log_error "Invalid flags: --json and --compact cannot be used together"
    exit 1
  fi

  if [[ $WW_FLAG_JSON -eq 1 ]]; then
    WW_OUTPUT_MODE="json"
  elif [[ $WW_FLAG_COMPACT -eq 1 ]]; then
    WW_OUTPUT_MODE="compact"
  else
    WW_OUTPUT_MODE="human"
  fi

  WW_MAIN_ARGS=("${args[@]}")
}

resolve_scope_context() {
  if [[ $WW_FLAG_GLOBAL -eq 1 ]]; then
    unset WARRIOR_PROFILE WORKWARRIOR_BASE TASKRC TASKDATA TIMEWARRIORDB
    return 0
  fi

  local selected_profile=""
  if [[ -n "$WW_FLAG_PROFILE" ]]; then
    selected_profile="$WW_FLAG_PROFILE"
  elif [[ -n "${WARRIOR_PROFILE:-}" && -d "${WORKWARRIOR_BASE:-}" ]]; then
    selected_profile="$WARRIOR_PROFILE"
  else
    selected_profile="$(get_last_profile 2>/dev/null || true)"
  fi

  if [[ -z "$selected_profile" ]]; then
    return 0
  fi

  if ! validate_profile_name "$selected_profile" >/dev/null 2>&1; then
    log_error "Invalid profile name: $selected_profile"
    exit 1
  fi

  local selected_base="$WW_BASE/profiles/$selected_profile"
  if [[ ! -d "$selected_base" ]]; then
    log_error "Profile '$selected_profile' does not exist at $selected_base"
    exit 1
  fi

  export WARRIOR_PROFILE="$selected_profile"
  export WORKWARRIOR_BASE="$selected_base"
  export TASKRC="$selected_base/.taskrc"
  export TASKDATA="$selected_base/.task"
  export TIMEWARRIORDB="$selected_base/.timewarrior"
  set_last_profile "$selected_profile" >/dev/null 2>&1 || true
}

# ============================================================================
# PROFILE COMMAND
# ============================================================================

cmd_profile() {
  local action="${1:-}"
  shift 2>/dev/null || true

  case "$action" in
    create)
      if [[ -z "$1" ]]; then
        log_error "Profile name required"
        echo "Usage: ww profile create <name>"
        exit 1
      fi
      "$WW_BASE/scripts/create-ww-profile.sh" "$@"
      ;;
    list)
      if [[ "$WW_OUTPUT_MODE" == "json" || "$WW_OUTPUT_MODE" == "compact" ]]; then
        local profiles=()
        while IFS= read -r -d '' dir; do
          profiles+=( "$(basename "$dir")" )
        done < <(command find "$WW_BASE/profiles" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
        if (( ${#profiles[@]} > 0 )); then
          mapfile -t profiles < <(printf '%s\n' "${profiles[@]}" | sort)
        fi
        if [[ "$WW_OUTPUT_MODE" == "json" ]]; then
          print_json_array "${profiles[@]}"
          echo ""
        else
          if (( ${#profiles[@]} > 0 )); then
            printf '%s\n' "${profiles[@]}"
          fi
        fi
      else
        "$WW_BASE/scripts/manage-profiles.sh" list "$@"
      fi
      ;;
    info)
      if [[ -z "$1" ]]; then
        log_error "Profile name required"
        echo "Usage: ww profile info <name>"
        exit 1
      fi
      "$WW_BASE/scripts/manage-profiles.sh" info "$@"
      ;;
    delete)
      if [[ -z "$1" ]]; then
        log_error "Profile name required"
        echo "Usage: ww profile delete <name>"
        exit 1
      fi
      "$WW_BASE/scripts/manage-profiles.sh" delete "$@"
      ;;
    backup)
      if [[ -z "$1" ]]; then
        log_error "Profile name required"
        echo "Usage: ww profile backup <name> [dest]"
        exit 1
      fi
      "$WW_BASE/scripts/manage-profiles.sh" backup "$@"
      ;;
    import)
      if [[ -z "$1" ]]; then
        log_error "Archive path required"
        echo "Usage: ww profile import <archive> [new-name]"
        exit 1
      fi
      "$WW_BASE/scripts/manage-profiles.sh" import "$@"
      ;;
    restore)
      if [[ -z "$1" || -z "$2" ]]; then
        log_error "Profile name and archive path required"
        echo "Usage: ww profile restore <name> <archive>"
        exit 1
      fi
      "$WW_BASE/scripts/manage-profiles.sh" restore "$@"
      ;;
    urgency)
      local urg_script="$WW_BASE/services/profile/urgency.sh"
      if [[ ! -f "$urg_script" ]]; then
        log_error "Urgency service not found at $urg_script"
        exit 1
      fi
      WORKWARRIOR_BASE="${WORKWARRIOR_BASE:-}" WARRIOR_PROFILE="${WARRIOR_PROFILE:-}" \
        bash "$urg_script" "$@"
      ;;
    uda|udas)
      local uda_script="$WW_BASE/services/profile/subservices/profile-uda.sh"
      if [[ ! -f "$uda_script" ]]; then
        log_error "UDA service not found at $uda_script"
        exit 1
      fi
      # 'udas' with no further args → shortcut for 'uda list'
      if [[ "$action" == "udas" && -z "${1:-}" ]]; then
        set -- "list"
      fi
      WORKWARRIOR_BASE="${WORKWARRIOR_BASE:-}" WARRIOR_PROFILE="${WARRIOR_PROFILE:-}" \
        bash "$uda_script" "$@"
      ;;
    ""|help|-h|--help)
      show_help_profile
      ;;
    *)
      log_error "Unknown profile action: $action"
      echo "Run 'ww profile help' for usage"
      exit 1
      ;;
  esac
}

# ============================================================================
# SERVICE COMMAND
# ============================================================================

service_category_description() {
  local category="$1"
  case "$category" in
    profile) echo "Profile lifecycle and activation tooling" ;;
    questions) echo "Prompt templates and structured intake workflows" ;;
    scripts) echo "General utility scripts and one-off automations" ;;
    export) echo "Export data from tools into standard formats" ;;
    diagnostic) echo "System checks and troubleshooting helpers" ;;
    find) echo "Cross-profile search and discovery utilities" ;;
    verify) echo "Validation scripts for integrity and config checks" ;;
    custom) echo "Interactive profile configuration helpers" ;;
    groups) echo "Profile grouping and membership management" ;;
    models) echo "LLM provider/model registry configuration" ;;
    extensions) echo "External tool extension registries" ;;
    x-delete) echo "Profile/data deletion workflows" ;;
    *) echo "Service category" ;;
  esac
}

service_category_scope() {
  local category="$1"
  case "$category" in
    groups|models|extensions|x-delete)
      echo "Global scope (active profile not required)"
      ;;
    *)
      echo "Profile-aware (active profile may override global service scripts)"
      ;;
  esac
}

service_category_syntax() {
  local category="$1"
  case "$category" in
    profile) echo "ww profile <create|list|info|delete|backup>" ;;
    groups) echo "ww group <list|show|create|add|remove|delete>" ;;
    models) echo "ww model <list|providers|env|check|show|add-provider|add-model|set-default|remove-model>" ;;
    extensions) echo "ww extensions <tool> <action>" ;;
    custom) echo "ww custom <journals|tasks|times|ledgers|issues|list>" ;;
    find) echo "ww find <term> [--type <type>] [--profile <name>]" ;;
    x-delete) echo "ww x <action> (destructive; review help first)" ;;
    *)
      echo "No dedicated ww namespace; run scripts from services/$category/ directly"
      ;;
  esac
}

collect_service_categories() {
  local categories=()

  if [[ -d "$WW_BASE/services" ]]; then
    while IFS= read -r -d '' dir; do
      categories+=( "$(basename "$dir")" )
    done < <(command find "$WW_BASE/services" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
  fi

  if [[ -n "${WORKWARRIOR_BASE:-}" ]] && [[ -d "$WORKWARRIOR_BASE/services" ]]; then
    while IFS= read -r -d '' dir; do
      categories+=( "$(basename "$dir")" )
    done < <(command find "$WORKWARRIOR_BASE/services" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
  fi

  if (( ${#categories[@]} > 0 )); then
    printf '%s\n' "${categories[@]}" | sort -u
  fi
}

count_service_files_in_dir() {
  local dir="$1"
  if [[ -z "$dir" || ! -d "$dir" ]]; then
    echo "0"
    return 0
  fi

  local count=0
  while IFS= read -r -d '' file; do
    if [[ -x "$file" || "$file" == *.sh ]]; then
      count=$((count + 1))
    fi
  done < <(command find "$dir" -maxdepth 1 -type f -print0 2>/dev/null)
  echo "$count"
}

service_help_topic_alias() {
  local name="${1:-}"
  case "$name" in
    groups) echo "group" ;;
    models) echo "model" ;;
    journals) echo "journal" ;;
    ledgers) echo "ledger" ;;
    service|services|profile|group|model|journal|ledger|extensions|find|custom|shortcut|deps)
      echo "$name"
      ;;
    *) echo "" ;;
  esac
}

cmd_service() {
  local action="${1:-}"
  shift 2>/dev/null || true

  case "$action" in
    list)
      local categories=()
      mapfile -t categories < <(collect_service_categories)
      local service_rows=()
      local category
      for category in "${categories[@]}"; do
        local services
        services="$(discover_services "$category" 2>/dev/null || true)"
        local count=0
        if [[ -n "$services" ]]; then
          count="$(printf '%s\n' "$services" | sed '/^$/d' | wc -l | tr -d ' ')"
        fi
        if [[ "$count" -eq 0 ]]; then
          continue
        fi
        local desc
        desc="$(service_category_description "$category")"
        service_rows+=( "$category:$count:$desc" )
      done
      if [[ "$WW_OUTPUT_MODE" == "json" ]]; then
        local first=1
        printf '['
        for row in "${service_rows[@]}"; do
          local category="${row%%:*}"
          local tail="${row#*:}"
          local count="${tail%%:*}"
          local desc="${tail#*:}"
          if [[ $first -eq 0 ]]; then
            printf ','
          fi
          first=0
          printf '{"category":"%s","count":%s,"description":"%s"}' "$category" "$count" "$desc"
        done
        printf ']\n'
      elif [[ "$WW_OUTPUT_MODE" == "compact" ]]; then
        for row in "${service_rows[@]}"; do
          local category="${row%%:*}"
          local tail="${row#*:}"
          local count="${tail%%:*}"
          echo "$category $count"
        done
      else
        echo "Available service categories:"
        echo ""
        for row in "${service_rows[@]}"; do
          local category="${row%%:*}"
          local tail="${row#*:}"
          local count="${tail%%:*}"
          local desc="${tail#*:}"
          echo "  $category ($count services) - $desc"
        done
        echo ""
      fi
      ;;
    info)
      local category="${1:-}"
      if [[ -z "$category" ]]; then
        log_error "Service category required"
        echo "Usage: ww service info <name>"
        exit 1
      fi

      local global_dir="$WW_BASE/services/$category"
      local profile_dir=""
      if [[ -n "${WORKWARRIOR_BASE:-}" ]]; then
        profile_dir="$WORKWARRIOR_BASE/services/$category"
      fi

      if [[ ! -d "$global_dir" && ( -z "$profile_dir" || ! -d "$profile_dir" ) ]]; then
        log_error "Unknown service category: $category"
        echo "Run 'ww service list' to see available categories."
        exit 1
      fi

      local merged_count=0
      local merged_services
      merged_services="$(discover_services "$category" 2>/dev/null || true)"
      if [[ -n "$merged_services" ]]; then
        merged_count="$(printf '%s\n' "$merged_services" | sed '/^$/d' | wc -l | tr -d ' ')"
      fi

      local global_count=0
      if [[ -d "$global_dir" ]]; then
        global_count="$(count_service_files_in_dir "$global_dir")"
      fi

      local profile_count=0
      if [[ -n "$profile_dir" && -d "$profile_dir" ]]; then
        profile_count="$(count_service_files_in_dir "$profile_dir")"
      fi

      local desc
      desc="$(service_category_description "$category")"
      local scope
      scope="$(service_category_scope "$category")"
      local syntax
      syntax="$(service_category_syntax "$category")"

      if [[ "$WW_OUTPUT_MODE" == "json" ]]; then
        printf '{"category":"%s","description":"%s","scope":"%s","syntax":"%s","services":{"resolved":%s,"global":%s,"profile":%s}' \
          "$category" "$desc" "$scope" "$syntax" "$merged_count" "$global_count" "$profile_count"
        if [[ -n "${WARRIOR_PROFILE:-}" ]]; then
          printf ',"active_profile":"%s"' "$WARRIOR_PROFILE"
        fi
        printf '}\n'
      else
        echo "Service category: $category"
        echo "Description: $desc"
        echo "Scope: $scope"
        echo "Primary syntax: $syntax"
        echo "Service files: $merged_count resolved ($global_count global, $profile_count profile)"
        if [[ -n "${WARRIOR_PROFILE:-}" ]]; then
          echo "Active profile context: $WARRIOR_PROFILE"
        fi
      fi
      ;;
    help)
      local topic="${1:-}"
      if [[ -z "$topic" ]]; then
        show_help_service
        return 0
      fi

      local mapped
      mapped="$(service_help_topic_alias "$topic")"
      if [[ -n "$mapped" ]]; then
        show_service_help "$mapped"
        return 0
      fi
      cmd_service info "$topic"
      ;;
    ""|help|-h|--help)
      show_help_service
      ;;
    *)
      log_error "Unknown service action: $action"
      echo "Run 'ww service help' for usage"
      exit 1
      ;;
  esac
}

# ============================================================================
# DEPS COMMAND
# ============================================================================

cmd_deps() {
  local action="${1:-}"
  shift 2>/dev/null || true

  # Source dependency installer
  if [[ -f "$WW_BASE/lib/dependency-installer.sh" ]]; then
    source "$WW_BASE/lib/dependency-installer.sh"
  else
    log_error "Dependency installer not found"
    exit 1
  fi

  case "$action" in
    check)
      check_all_dependencies
      display_dependency_status
      ;;
    install)
      run_dependency_installer
      ;;
    ""|help|-h|--help)
      cat << EOF
Dependency Management

Usage: ww deps <action>

Actions:
  check       Check installed dependencies and their versions
  install     Interactive dependency installation

External Dependencies:
  • TaskWarrior  - Task management (task)
  • TimeWarrior  - Time tracking (timew)
  • Hledger      - Ledger accounting (hledger)
  • JRNL         - Journaling (jrnl)

Examples:
  ww deps check     Show dependency status
  ww deps install   Install missing dependencies

EOF
      ;;
    *)
      log_error "Unknown deps action: $action"
      echo "Run 'ww deps help' for usage"
      exit 1
      ;;
  esac
}

