cmd_ledger() {
  local action="${1:-}"
  shift 2>/dev/null || true

  case "$action" in
    list|"")
      if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name>."
        exit 1
      fi
      local cfg="$WORKWARRIOR_BASE/ledgers.yaml"
      if [[ ! -f "$cfg" ]]; then
        log_error "ledgers.yaml not found: $cfg"
        exit 1
      fi
      local names=()
      mapfile -t names < <(awk '
        /^ledgers:/ { in_l=1; next }
        in_l && /^[^ ]/ { in_l=0 }
        in_l && /^  [a-zA-Z0-9_-]+:/ {
          name=$1; sub(":", "", name);
          if (name != "default") print "  • " name
        }
      ' "$cfg"
      )
      local clean=()
      for entry in "${names[@]}"; do
        clean+=( "${entry#  • }" )
      done
      if [[ "$WW_OUTPUT_MODE" == "json" ]]; then
        printf '{"profile":"%s","ledgers":' "${WARRIOR_PROFILE:-active}"
        print_json_array "${clean[@]}"
        printf '}\n'
      elif [[ "$WW_OUTPUT_MODE" == "compact" ]]; then
        if (( ${#clean[@]} > 0 )); then
          printf '%s\n' "${clean[@]}"
        fi
      else
        echo "Ledgers (${WARRIOR_PROFILE:-active}):"
        if (( ${#clean[@]} > 0 )); then
          printf '  • %s\n' "${clean[@]}"
        else
          echo "  (none)"
        fi
      fi
      ;;
    add|create)
      if [[ -z "${WARRIOR_PROFILE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name> or use --profile."
        exit 1
      fi
      if [[ -z "${1:-}" ]]; then
        log_error "Ledger name required"
        echo "Usage: ww ledger add <name>"
        exit 1
      fi
      if ! add_ledger_to_profile "$WARRIOR_PROFILE" "$1"; then
        exit 1
      fi
      ;;
    remove|delete|rm)
      if [[ -z "${WARRIOR_PROFILE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name> or use --profile."
        exit 1
      fi
      if [[ -z "${1:-}" ]]; then
        log_error "Ledger name required"
        echo "Usage: ww ledger remove <name>"
        exit 1
      fi
      if ! remove_ledger_from_profile "$WARRIOR_PROFILE" "$1"; then
        exit 1
      fi
      ;;
    rename)
      if [[ -z "${WARRIOR_PROFILE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name> or use --profile."
        exit 1
      fi
      if [[ -z "${1:-}" || -z "${2:-}" ]]; then
        log_error "Old and new ledger names required"
        echo "Usage: ww ledger rename <old> <new>"
        exit 1
      fi
      if ! rename_ledger_in_profile "$WARRIOR_PROFILE" "$1" "$2"; then
        exit 1
      fi
      ;;
    help|-h|--help)
      show_help_ledger
      ;;
    *)
      log_error "Unknown ledger action: $action"
      echo "Run 'ww ledger help' for usage"
      exit 1
      ;;
  esac
}

# ============================================================================
# ISSUES COMMAND
# ============================================================================

cmd_issues() {
  # Parse all args: first non-flag is the subcommand; strip --json from remaining
  local json_mode=0
  local subcommand=""
  local remaining=()
  for arg in "$@"; do
    if [[ "$arg" == "--json" ]]; then
      json_mode=1
    elif [[ -z "$subcommand" && "$arg" != --* ]]; then
      subcommand="$arg"
    else
      remaining+=("$arg")
    fi
  done
  set -- "${remaining[@]+"${remaining[@]}"}"

  case "$subcommand" in
    ""|help|--help|-h)
      cat << 'EOF'
Issues Service

Routes to bugwarrior (one-way pull) or github-sync (two-way):

  ww issues pull [--dry-run] [--json]              Pull issues from all configured services
  ww issues uda                                     List TaskWarrior UDAs for configured services

  ww issues push [task-id]                          Push task changes to GitHub
  ww issues sync [task-id]                          Bidirectional sync with GitHub
  ww issues enable-sync <task-id> <issue> <repo>    Enable GitHub sync for a task
  ww issues disable-sync <task-id>                  Disable GitHub sync for a task
  ww issues status [--json]                         Show GitHub sync status

  ww issues custom                                  Configure issue services interactively
  ww issues help                                    Show this help

Note: 'ww issues' and 'i' are synonymous.
Requires an active profile: p-<profile-name>

Bugwarrior is one-way only (external services → TaskWarrior).
For two-way GitHub sync, use: ww issues push / sync / enable-sync

EOF
      ;;
    custom)
      if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
        log_error "Issues service requires an active profile"
        echo "Activate a profile with: p-<profile-name>" >&2
        exit 1
      fi
      WORKWARRIOR_BASE="$WORKWARRIOR_BASE" WARRIOR_PROFILE="$WARRIOR_PROFILE" \
        "$WW_BASE/services/custom/configure-issues.sh" "$@"
      ;;
    push|sync|enable-sync|enable|disable-sync|disable|status|sync-status)
      if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
        log_error "Issues service requires an active profile"
        echo "Activate a profile with: p-<profile-name>" >&2
        exit 1
      fi
      local github_sync_cli="$WW_BASE/services/custom/github-sync.sh"
      if [[ ! -f "$github_sync_cli" ]]; then
        log_error "GitHub sync CLI not found at $github_sync_cli"
        exit 1
      fi
      local sync_command
      case "$subcommand" in
        enable-sync|enable) sync_command="enable" ;;
        disable-sync|disable) sync_command="disable" ;;
        sync-status|status) sync_command="status" ;;
        *) sync_command="$subcommand" ;;
      esac
      if [[ "$sync_command" == "status" && "$json_mode" -eq 1 ]]; then
        local sync_output sync_exit=0
        sync_output=$(WORKWARRIOR_BASE="$WORKWARRIOR_BASE" WARRIOR_PROFILE="$WARRIOR_PROFILE" \
          "$github_sync_cli" "$sync_command" "$@" 2>&1) || sync_exit=$?
        local escaped="${sync_output//\\/\\\\}"
        escaped="${escaped//\"/\\\"}"
        escaped="${escaped//$'\n'/\\n}"
        if [[ "$sync_exit" -eq 0 ]]; then
          echo "{\"command\":\"status\",\"status\":\"success\",\"output\":\"${escaped}\"}"
        else
          echo "{\"command\":\"status\",\"status\":\"failed\",\"exit_code\":${sync_exit},\"output\":\"${escaped}\"}"
        fi
        exit "$sync_exit"
      fi
      WORKWARRIOR_BASE="$WORKWARRIOR_BASE" WARRIOR_PROFILE="$WARRIOR_PROFILE" \
        "$github_sync_cli" "$sync_command" "$@"
      ;;
    uda)
      echo "Note: UDA management has moved to 'ww profile uda'." >&2
      echo "  ww profile uda list      — view all UDAs" >&2
      echo "  ww profile uda add       — add a new UDA" >&2
      echo "  ww profile uda perm      — set sync permissions per UDA" >&2
      echo "" >&2
      echo "Redirecting to: ww profile uda list ..." >&2
      echo "" >&2
      local uda_script="$WW_BASE/services/profile/subservices/profile-uda.sh"
      if [[ ! -f "$uda_script" ]]; then
        log_error "UDA service not found at $uda_script"
        exit 1
      fi
      if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
        log_error "Issues service requires an active profile"
        echo "Activate a profile with: p-<profile-name>" >&2
        exit 1
      fi
      WORKWARRIOR_BASE="${WORKWARRIOR_BASE}" WARRIOR_PROFILE="${WARRIOR_PROFILE:-}" \
        bash "$uda_script" list
      ;;
    pull|*)
      if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
        log_error "Issues service requires an active profile"
        echo "Activate a profile with: p-<profile-name>" >&2
        exit 1
      fi
      local bugwarrior_config="$WORKWARRIOR_BASE/.config/bugwarrior/bugwarriorrc"
      if [[ ! -f "$bugwarrior_config" ]]; then
        bugwarrior_config="$WORKWARRIOR_BASE/.config/bugwarrior/bugwarrior.toml"
        if [[ ! -f "$bugwarrior_config" ]]; then
          log_error "Bugwarrior configuration not found"
          echo "Run 'ww issues custom' to configure the issues service" >&2
          exit 1
        fi
      fi
      if ! command -v bugwarrior &>/dev/null; then
        log_error "bugwarrior is not installed"
        echo "Install with: pipx install bugwarrior && pipx inject bugwarrior setuptools" >&2
        exit 1
      fi
      if [[ "$subcommand" == "pull" && "$json_mode" -eq 0 ]]; then
        echo "⚠️  One-way sync: External services → TaskWarrior"
        echo "   Changes in TaskWarrior will NOT sync back to issue trackers"
        echo "   For two-way GitHub sync, use: ww issues push / sync / enable-sync"
        echo ""
      fi
      if [[ "$json_mode" -eq 1 ]]; then
        local bw_exit=0
        BUGWARRIORRC="$bugwarrior_config" \
        BUGWARRIOR_TASKRC="$WORKWARRIOR_BASE/.taskrc" \
        BUGWARRIOR_TASKDATA="$WORKWARRIOR_BASE/.task" \
          bugwarrior "$subcommand" "$@" >/dev/null 2>&1 || bw_exit=$?
        if [[ "$bw_exit" -eq 0 ]]; then
          echo "{\"command\":\"${subcommand}\",\"status\":\"success\"}"
        else
          echo "{\"command\":\"${subcommand}\",\"status\":\"failed\",\"exit_code\":${bw_exit}}"
        fi
        exit "$bw_exit"
      fi
      BUGWARRIORRC="$bugwarrior_config" \
      BUGWARRIOR_TASKRC="$WORKWARRIOR_BASE/.taskrc" \
      BUGWARRIOR_TASKDATA="$WORKWARRIOR_BASE/.task" \
        bugwarrior "$subcommand" "$@"
      ;;
  esac
}

# ============================================================================
# MAIN DISPATCHER
# ============================================================================

main() {
  parse_global_flags "$@"
  set -- "${WW_MAIN_ARGS[@]}"
  local command="${1:-}"
  shift 2>/dev/null || true

  export WW_OUTPUT_MODE
  export WW_VERBOSE

  if [[ $WW_FLAG_HELP -eq 1 ]]; then
    if [[ -n "$command" ]]; then
      show_service_help "$command"
    else
      show_usage
    fi
    return 0
  fi

  resolve_scope_context

  case "$command" in
    profile|p)
      cmd_profile "$@"
      ;;
    profiles)
      nudge_preferred_syntax "ww profiles" "ww profile list"
      cmd_profile list "$@"
      ;;
    service|s)
      cmd_service "$@"
      ;;
    services)
      nudge_preferred_syntax "ww services" "ww service list"
      if [[ $# -eq 0 ]]; then
        cmd_service list
      else
        cmd_service "$@"
      fi
      ;;
    group)
      cmd_group "$@"
      ;;
    groups)
      if [[ $# -eq 0 ]]; then
        nudge_preferred_syntax "ww groups" "ww group list"
      else
        nudge_preferred_syntax "ww groups <action>" "ww group <action>"
      fi
      if [[ $# -eq 0 ]]; then
        cmd_group list
      else
        cmd_group "$@"
      fi
      ;;
    model)
      cmd_models "$@"
      ;;
    models)
      if [[ $# -eq 0 ]]; then
        nudge_preferred_syntax "ww models" "ww model list"
      else
        nudge_preferred_syntax "ww models <action>" "ww model <action>"
      fi
      if [[ $# -eq 0 ]]; then
        cmd_models list
      else
        cmd_models "$@"
      fi
      ;;
    journal)
      cmd_journal "$@"
      ;;
    journals)
      if [[ $# -eq 0 ]]; then
        nudge_preferred_syntax "ww journals" "ww journal list"
      else
        nudge_preferred_syntax "ww journals <action>" "ww journal <action>"
      fi
      if [[ $# -eq 0 ]]; then
        cmd_journal list
      else
        cmd_journal "$@"
      fi
      ;;
    ledger)
      cmd_ledger "$@"
      ;;
    ledgers)
      if [[ $# -eq 0 ]]; then
        nudge_preferred_syntax "ww ledgers" "ww ledger list"
      else
        nudge_preferred_syntax "ww ledgers <action>" "ww ledger <action>"
      fi
      if [[ $# -eq 0 ]]; then
        cmd_ledger list
      else
        cmd_ledger "$@"
      fi
      ;;
    extensions)
      cmd_extensions "$@"
      ;;
    find)
      cmd_find "$@"
      ;;
    issues)
      cmd_issues "$@"
      ;;
    custom)
      cmd_custom "$@"
      ;;
    shortcut)
      cmd_shortcut "$@"
      ;;
    export|e)
      if [[ -f "$WW_BASE/services/export/export.sh" ]]; then
        "$WW_BASE/services/export/export.sh" "$@"
      else
        log_error "Export service not found"
        exit 1
      fi
      ;;
    x)
      if [[ -f "$WW_BASE/services/x-delete/x.sh" ]]; then
        "$WW_BASE/services/x-delete/x.sh" "$@"
      else
        log_error "Delete service not found"
        exit 1
      fi
      ;;
    deps|d)
      cmd_deps "$@"
      ;;
    version|--version|-v)
      show_version
      ;;
    help|--help|-h|"")
      if [[ -n "${1:-}" ]]; then
        show_service_help "$1"
      else
        show_usage
      fi
      ;;
    *)
      log_error "Unknown command: $command"
      echo ""
      echo "Run 'ww help' for usage"
      exit 1
      ;;
  esac
}

main "$@"
