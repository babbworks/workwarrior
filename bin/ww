# ============================================================================
# CUSTOM COMMAND
# ============================================================================

cmd_custom() {
  local action="${1:-}"
  shift 2>/dev/null || true

  case "$action" in
    journals)
      "$WW_BASE/services/custom/configure-journals.sh" "$@"
      ;;
    tasks)
      "$WW_BASE/services/custom/configure-tasks.sh" "$@"
      ;;
    times)
      "$WW_BASE/services/custom/configure-times.sh" "$@"
      ;;
    ledgers)
      "$WW_BASE/services/custom/configure-ledgers.sh" "$@"
      ;;
    issues)
      "$WW_BASE/services/custom/configure-issues.sh" "$@"
      ;;
    list)
      echo "Available custom services:"
      echo ""
      for service in "$WW_BASE/services/custom/"*.sh; do
        if [[ -f "$service" && -x "$service" ]]; then
          local name
          name="$(basename "$service" .sh)"
          # Extract description from service file
          local desc
          desc=$(grep "^# Description:" "$service" | sed 's/# Description: //')
          if [[ -n "$desc" ]]; then
            echo "  $name - $desc"
          else
            echo "  $name"
          fi
        fi
      done
      echo ""
      echo "Usage: ww custom <service-name>"
      echo "   or: j custom (for journals configuration)"
      echo "   or: custom journals (alternative)"
      echo ""
      ;;
    ""|help|-h|--help)
      cat << EOF
Custom Services

Usage: ww custom <service> [arguments]

Available Services:
  journals   Configure journal settings (requires active profile)
  tasks      Configure TaskWarrior settings (requires active profile)
  times      Configure TimeWarrior settings (requires active profile)
  ledgers    Configure ledger settings (requires active profile)
  issues     Configure bugwarrior issue synchronization (requires active profile)

Shortcuts:
  j custom              Same as 'ww custom journals'
  t custom              Same as 'ww custom tasks'
  a custom              Same as 'ww custom times'
  l custom              Same as 'ww custom ledgers' (profile-scoped only)
  i custom              Same as 'ww custom issues'
  custom journals       Same as 'ww custom journals'
  custom tasks          Same as 'ww custom tasks'
  custom times          Same as 'ww custom times'
  custom ledgers        Same as 'ww custom ledgers'
  custom issues         Same as 'ww custom issues'

Examples:
  ww custom journals    Configure journal settings
  ww custom tasks       Configure TaskWarrior settings
  ww custom times       Configure TimeWarrior settings
  ww custom ledgers     Configure ledger settings
  ww custom issues      Configure issue synchronization
  ww custom list        List available custom services
  j custom              Quick access to journal configuration
  l custom              Quick access to ledger configuration
  i custom              Quick access to issues configuration

Note: Most custom services require an active profile.
Activate a profile with: p-<profile-name>

EOF
      ;;
    *)
      log_error "Unknown custom service: $action"
      echo "Run 'ww custom list' to see available services"
      exit 1
      ;;
  esac
}

# ============================================================================
# SHORTCUT COMMAND
# ============================================================================

cmd_shortcut() {
  local action="${1:-}"
  shift 2>/dev/null || true

  # Source shortcut registry library
  if [[ -f "$WW_BASE/lib/shortcode-registry.sh" ]]; then
    source "$WW_BASE/lib/shortcode-registry.sh"
  else
    log_error "Shortcut registry not found"
    exit 1
  fi

  case "$action" in
    list|"")
      display_shortcuts "${1:-all}"
      ;;
    compact)
      display_shortcuts_compact
      ;;
    info)
      if [[ -z "${1:-}" ]]; then
        log_error "Shortcut key required"
        echo "Usage: ww shortcut info <key>"
        exit 1
      fi
      display_shortcut_info "$1"
      ;;
    add)
      if [[ -z "${1:-}" || -z "${2:-}" || -z "${3:-}" || -z "${4:-}" || -z "${5:-}" ]]; then
        log_error "Missing arguments for shortcut add"
        echo "Usage: ww shortcut add <key> <name> <category> <description> <command> [requires_profile]"
        exit 1
      fi
      add_user_shortcut "$1" "$2" "$3" "$4" "$5" "${6:-false}"
      ;;
    remove|rm|delete)
      if [[ -z "${1:-}" ]]; then
        log_error "Shortcut key required"
        echo "Usage: ww shortcut remove <key>"
        exit 1
      fi
      remove_user_shortcut "$1"
      ;;
    help|-h|--help)
      cat << EOF
Shortcut Reference

Usage: ww shortcut <action> [arguments]

Actions:
  list [category]   List shortcuts (categories: all, profile, function, service, global)
  info <key>        Show details for a shortcut
  compact           Compact list (for quick reference)
  add <args>        Add or update a user shortcut override
  remove <key>      Remove a user shortcut override

Examples:
  ww shortcut list
  ww shortcut list profile
  ww shortcut info j
  ww shortcut compact
  ww shortcut add x "Example" global "Example command" "echo hi" false
  ww shortcut remove x

EOF
      ;;
    *)
      log_error "Unknown shortcut action: $action"
      echo "Run 'ww shortcut help' for usage"
      exit 1
      ;;
  esac
}

# ============================================================================
# JOURNAL COMMAND (list-first UX)
# ============================================================================

cmd_journal() {
  local action="${1:-}"
  shift 2>/dev/null || true

  case "$action" in
    list|"")
      if [[ -z "${WORKWARRIOR_BASE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name>."
        exit 1
      fi
      local cfg="$WORKWARRIOR_BASE/jrnl.yaml"
      if [[ ! -f "$cfg" ]]; then
        log_error "jrnl.yaml not found: $cfg"
        exit 1
      fi
      local names=()
      mapfile -t names < <(awk '
        /^journals:/ { in_j=1; next }
        in_j && /^[^ ]/ { in_j=0 }
        in_j && /^  [a-zA-Z0-9_-]+:/ {
          name=$1; sub(":", "", name);
          if (name != "default") print "  • " name
        }
      ' "$cfg"
      )
      local clean=()
      for entry in "${names[@]}"; do
        clean+=( "${entry#  • }" )
      done
      if [[ "$WW_OUTPUT_MODE" == "json" ]]; then
        printf '{"profile":"%s","journals":' "${WARRIOR_PROFILE:-active}"
        print_json_array "${clean[@]}"
        printf '}\n'
      elif [[ "$WW_OUTPUT_MODE" == "compact" ]]; then
        if (( ${#clean[@]} > 0 )); then
          printf '%s\n' "${clean[@]}"
        fi
      else
        echo "Journals (${WARRIOR_PROFILE:-active}):"
        if (( ${#clean[@]} > 0 )); then
          printf '  • %s\n' "${clean[@]}"
        else
          echo "  (none)"
        fi
      fi
      ;;
    add|create)
      if [[ -z "${WARRIOR_PROFILE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name> or use --profile."
        exit 1
      fi
      if [[ -z "${1:-}" ]]; then
        log_error "Journal name required"
        echo "Usage: ww journal add <name>"
        exit 1
      fi
      if ! add_journal_to_profile "$WARRIOR_PROFILE" "$1"; then
        exit 1
      fi
      ;;
    remove|delete|rm)
      if [[ -z "${WARRIOR_PROFILE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name> or use --profile."
        exit 1
      fi
      if [[ -z "${1:-}" ]]; then
        log_error "Journal name required"
        echo "Usage: ww journal remove <name>"
        exit 1
      fi
      if ! remove_journal_from_profile "$WARRIOR_PROFILE" "$1"; then
        exit 1
      fi
      ;;
    rename)
      if [[ -z "${WARRIOR_PROFILE:-}" ]]; then
        log_error "No active profile. Activate one with p-<profile-name> or use --profile."
        exit 1
      fi
      if [[ -z "${1:-}" || -z "${2:-}" ]]; then
        log_error "Old and new journal names required"
        echo "Usage: ww journal rename <old> <new>"
        exit 1
      fi
      if ! rename_journal_in_profile "$WARRIOR_PROFILE" "$1" "$2"; then
        exit 1
      fi
      ;;
    help|-h|--help)
      show_help_journal
      ;;
    *)
      log_error "Unknown journal action: $action"
      echo "Run 'ww journal help' for usage"
      exit 1
      ;;
  esac
}

